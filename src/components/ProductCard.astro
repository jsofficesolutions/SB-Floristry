---
// src/components/ProductCard.astro
const { product, isDark = false } = Astro.props;

// Safely extract price, images, and crucial Variant ID for checkout
const variantId = product.variants?.edges[0]?.node?.id || product.id;
const priceAmount = product.variants?.edges[0]?.node?.price?.amount || '0.00';
const priceText = `£${parseFloat(priceAmount).toFixed(2)}`;
const images = product.images?.edges.map(e => String(e.node.url)) || [];
const img1 = String(images[0] || 'https://via.placeholder.com/400x500?text=No+Image');
const img2 = images[1] || null;

// Theming variables matching index.html
const textClass = isDark ? "text-sb-cream" : "text-sb-black";
const subText = isDark ? "text-sb-gold" : "text-gray-500";
const btnBg = isDark ? "bg-sb-cream text-sb-black hover:bg-sb-gold" : "bg-white/90 text-sb-black hover:bg-sb-black hover:text-white";
const borderClass = isDark ? "border border-white/10" : "";

// Generate the URL for the new dedicated product page
const productUrl = `/products/${product.handle}`;
---

<div class="group relative reveal active block">
  <div class={`relative overflow-hidden mb-4 aspect-[4/5] group-image-container bg-[#F9F8F6] ${borderClass}`}>
    
    <img 
      src={img1} 
      alt={product.title} 
      class={`w-full h-full object-cover absolute inset-0 transition-opacity duration-700 z-10 loaded ${img2 ? 'group-hover:opacity-0' : ''}`} 
    />
    
    {img2 && (
      <img src={img2} alt={`${product.title} alternate view`} class="w-full h-full object-cover absolute inset-0 z-0 opacity-100 loaded" />
    )}

    <a href={productUrl} class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white/90 text-sb-black w-10 h-10 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 z-20 hover:bg-sb-gold hover:text-sb-black">
      <i class="fas fa-eye"></i>
    </a>
    
    <button 
      class={`absolute bottom-0 left-0 w-full ${btnBg} py-4 translate-y-full group-hover:translate-y-0 transition-all duration-300 font-bold tracking-luxury text-[10px] uppercase z-30 add-to-cart-btn cursor-pointer`}
      data-id={variantId} 
      data-title={product.title} 
      data-price={priceAmount} 
      data-image={img1}
    >
      Add to Basket
    </button>
  </div>
  
  <a href={productUrl} class="block hover:opacity-80 transition-opacity">
    <h4 class={`font-serif text-2xl mb-1 font-light hover:text-sb-gold transition-colors ${textClass}`}>{product.title}</h4>
  </a>
  <p class={`font-medium text-base ${subText}`}>{priceText}</p>
</div>
