---
---
<div id="cartOverlay" class="fixed inset-0 bg-black/60 z-[100] hidden opacity-0 transition-opacity duration-300 backdrop-blur-sm"></div>

<div id="cartSidebar" class="fixed top-0 right-0 h-full w-full sm:w-[450px] bg-sb-cream z-[101] transform translate-x-full transition-transform duration-500 shadow-2xl flex flex-col">
    
    <div class="flex items-center justify-between p-6 border-b border-white/10 bg-sb-black text-sb-cream">
        <h2 class="font-serif text-3xl font-light">Your Basket</h2>
        <button id="closeCartBtn" type="button" class="text-gray-400 hover:text-sb-gold transition-colors p-2">
            <i class="fas fa-times text-xl pointer-events-none"></i>
        </button>
    </div>

    <div id="deliveryProgressContainer" class="bg-white text-sb-black text-center py-4 px-6 text-[10px] tracking-luxury uppercase font-bold border-b border-gray-200 hidden">
        <p id="deliveryProgressText">Spend £<span id="deliveryAmountNeeded">60.00</span> more for Free Local Delivery</p>
        <div class="w-full bg-gray-100 h-1.5 mt-3 rounded-full overflow-hidden">
            <div id="deliveryProgressBar" class="bg-sb-gold h-full w-0 transition-all duration-700 ease-out"></div>
        </div>
    </div>

    <div id="cartItemsContainer" class="flex-grow overflow-y-auto p-6 space-y-6 bg-[#F9F8F6]">
    </div>

    <div class="bg-white border-t border-gray-200 shadow-[0_-4px_15px_rgba(0,0,0,0.02)] z-10">
        
        <div class="border-b border-gray-100">
            <button type="button" class="flex items-center justify-between w-full text-left p-5 text-[11px] font-bold tracking-luxury uppercase text-sb-black group" id="toggleDeliveryDate">
                <span class="flex items-center pointer-events-none"><i class="fas fa-calendar-alt mr-3 text-sb-gold text-sm"></i> Select Delivery Date</span>
                <i class="fas fa-chevron-down text-[10px] transition-transform duration-300 group-hover:text-sb-gold pointer-events-none"></i>
            </button>
            <div id="deliveryDateSection" class="hidden px-5 pb-5 animate-fade-in">
                <input type="date" id="cartDeliveryDate" class="w-full bg-[#F9F8F6] border border-gray-200 p-3 text-sm focus:border-sb-gold outline-none transition-colors text-sb-black font-sans">
                <p class="text-[10px] text-gray-500 mt-2 italic">* We require 48 hours notice for bespoke arrangements.</p>
            </div>
        </div>

        <div>
            <button type="button" class="flex items-center justify-between w-full text-left p-5 text-[11px] font-bold tracking-luxury uppercase text-sb-black group" id="toggleGiftMessage">
                <span class="flex items-center pointer-events-none"><i class="fas fa-envelope-open-text mr-3 text-sb-gold text-sm"></i> Add a Gift Message</span>
                <i class="fas fa-chevron-down text-[10px] transition-transform duration-300 group-hover:text-sb-gold pointer-events-none"></i>
            </button>
            <div id="giftMessageSection" class="hidden px-5 pb-5 animate-fade-in">
                <textarea id="cartGiftMessage" rows="3" class="w-full bg-[#F9F8F6] border border-gray-200 p-3 text-sm focus:border-sb-gold outline-none transition-colors placeholder-gray-400 font-sans" placeholder="Write your personalized message here..."></textarea>
            </div>
        </div>
        
    </div>

    <div class="p-6 bg-sb-black text-sb-cream z-20 shadow-[0_-10px_20px_rgba(0,0,0,0.2)]">
        <div class="flex justify-between items-center mb-6">
            <span class="text-[11px] uppercase tracking-luxury text-gray-400">Subtotal</span>
            <span id="cartSubtotal" class="font-serif text-3xl text-sb-gold">£0.00</span>
        </div>
        <p class="text-[10px] text-gray-400 text-center mb-6 tracking-wide">Shipping & taxes calculated at checkout</p>
        
        <button id="checkoutBtn" type="button" class="w-full bg-sb-gold text-sb-black hover:bg-white transition-colors duration-300 py-4 text-[11px] uppercase tracking-[0.25em] font-bold shadow-lg shadow-sb-gold/20 relative overflow-hidden group">
            <span class="relative z-10 flex items-center justify-center gap-2 pointer-events-none">
                Proceed to Secure Checkout <i class="fas fa-lock text-[10px]"></i>
            </span>
        </button>
    </div>
</div>

<script is:inline>
    document.addEventListener('astro:page-load', () => {
        const dateInput = document.getElementById('cartDeliveryDate');
        if (dateInput) {
            const today = new Date();
            today.setDate(today.getDate() + 2);
            const yyyy = today.getFullYear();
            const mm = String(today.getMonth() + 1).padStart(2, '0');
            const dd = String(today.getDate()).padStart(2, '0');
            dateInput.min = `${yyyy}-${mm}-${dd}`;
        }

        document.getElementById('toggleDeliveryDate')?.addEventListener('click', function() {
            document.getElementById('deliveryDateSection')?.classList.toggle('hidden');
            this.querySelector('.fa-chevron-down')?.classList.toggle('rotate-180');
        });
        document.getElementById('toggleGiftMessage')?.addEventListener('click', function() {
            document.getElementById('giftMessageSection')?.classList.toggle('hidden');
            this.querySelector('.fa-chevron-down')?.classList.toggle('rotate-180');
        });

        const getCartElements = () => ({
            overlay: document.getElementById('cartOverlay'),
            sidebar: document.getElementById('cartSidebar'),
            container: document.getElementById('cartItemsContainer'),
            subtotal: document.getElementById('cartSubtotal'),
            count: document.getElementById('cartCount'),
            progressContainer: document.getElementById('deliveryProgressContainer'),
            progressText: document.getElementById('deliveryProgressText'),
            progressBar: document.getElementById('deliveryProgressBar')
        });

        const openCart = () => {
            const { overlay, sidebar } = getCartElements();
            if (!overlay || !sidebar) return;
            overlay.classList.remove('hidden');
            setTimeout(() => overlay.classList.remove('opacity-0'), 10);
            sidebar.classList.remove('translate-x-full');
            document.body.style.overflow = 'hidden';
        };

        const closeCart = () => {
            const { overlay, sidebar } = getCartElements();
            if (!overlay || !sidebar) return;
            overlay.classList.add('opacity-0');
            sidebar.classList.add('translate-x-full');
            setTimeout(() => overlay.classList.add('hidden'), 300);
            document.body.style.overflow = '';
        };

        document.getElementById('cartBtn')?.addEventListener('click', openCart);
        document.getElementById('closeCartBtn')?.addEventListener('click', closeCart);
        document.getElementById('cartOverlay')?.addEventListener('click', closeCart);

        const renderCart = () => {
            const cart = JSON.parse(localStorage.getItem('sb_cart') || '[]');
            const { container, subtotal, count, progressContainer, progressText, progressBar } = getCartElements();
            
            if (!container) return;

            if (cart.length === 0) {
                container.innerHTML = `
                    <div class="flex flex-col items-center justify-center h-64 text-center px-4">
                        <i class="fas fa-shopping-bag text-gray-300 text-3xl mb-4"></i>
                        <p class="font-serif text-xl text-sb-black mb-1">Your basket is empty</p>
                        <p class="text-[11px] text-gray-400 tracking-wide max-w-[200px]">Add some beautiful blooms to get started.</p>
                    </div>
                `;
                if (subtotal) subtotal.innerText = '£0.00';
                if (count) count.classList.add('hidden');
                if (progressContainer) progressContainer.classList.add('hidden');
                return;
            }

            let totalItems = 0;
            let subtotalAmount = 0;
            let itemsHtml = '';

            cart.forEach(item => {
                totalItems += item.quantity;
                subtotalAmount += parseFloat(item.price) * item.quantity;

                const finalImgSrc = (item.image && item.image !== 'undefined' && item.image !== 'null') 
                    ? item.image 
                    : 'https://via.placeholder.com/400x500?text=No+Image';

                itemsHtml += `
                    <div class="flex items-center gap-4 bg-white p-4 border border-gray-100 shadow-sm relative rounded-sm">
                        <img src="${finalImgSrc}" alt="${item.title}" class="w-20 h-24 object-cover shrink-0 bg-[#F9F8F6]" />
                        <div class="flex-grow flex flex-col justify-between h-24 py-1">
                            <div>
                                <h3 class="font-serif text-base text-sb-black font-light leading-tight pr-6">${item.title}</h3>
                                <p class="text-xs text-sb-gold font-bold mt-1">£${parseFloat(item.price).toFixed(2)}</p>
                            </div>
                            <div class="flex items-center border border-gray-200 w-fit rounded-sm bg-[#F9F8F6]">
                                <button type="button" class="decrease-qty border-r border-gray-200 px-2.5 py-1 text-xs text-gray-500 hover:text-sb-black hover:bg-gray-100 transition-colors font-bold" data-id="${item.id}">-</button>
                                <span class="px-3 text-xs font-bold text-sb-black min-w-[24px] text-center select-none">${item.quantity}</span>
                                <button type="button" class="increase-qty border-l border-gray-200 px-2.5 py-1 text-xs text-gray-500 hover:text-sb-black hover:bg-gray-100 transition-colors font-bold" data-id="${item.id}">+</button>
                            </div>
                        </div>
                        <button type="button" class="remove-item absolute top-4 right-4 text-gray-300 hover:text-red-500 transition-colors p-1" data-id="${item.id}" aria-label="Remove item">
                            <i class="fas fa-trash-alt text-sm pointer-events-none"></i>
                        </button>
                    </div>
                `;
            });

            container.innerHTML = itemsHtml;

            if (subtotal) subtotal.innerText = `£${subtotalAmount.toFixed(2)}`;
            if (count) {
                count.innerText = totalItems;
                count.classList.remove('hidden');
            }

            if (progressContainer && progressText && progressBar) {
                progressContainer.classList.remove('hidden');
                const threshold = 60.00;
                if (subtotalAmount >= threshold) {
                    progressText.innerHTML = '🎉 You qualify for <span class="text-green-600 font-bold">Free Local Delivery</span>!';
                    progressBar.style.width = '100%';
                } else {
                    const remaining = (threshold - subtotalAmount).toFixed(2);
                    progressText.innerHTML = `Spend £<span id="deliveryAmountNeeded" class="font-bold">${remaining}</span> more for Free Local Delivery`;
                    const progressPercentage = (subtotalAmount / threshold) * 100;
                    progressBar.style.width = `${progressPercentage}%`;
                }
            }
        };

        if (!window.cartListenersInitialized) {
            document.addEventListener('click', (e) => {
                const target = e.target;
                
                // 1. ADD ITEM ACTION
                if (target.classList.contains('add-to-cart-btn') || target.closest('.add-to-cart-btn')) {
                    const cart = JSON.parse(localStorage.getItem('sb_cart') || '[]');
                    const btn = target.classList.contains('add-to-cart-btn') ? target : target.closest('.add-to-cart-btn');
                    
                    const id = btn.getAttribute('data-id') || btn.dataset.id;
                    const title = btn.getAttribute('data-title') || btn.dataset.title;
                    const price = btn.getAttribute('data-price') || btn.dataset.price;
                    const image = btn.getAttribute('data-image') || btn.dataset.image;

                    if (!id) return;

                    const itemMatch = cart.find(item => item.id === id);
                    if (itemMatch) {
                        itemMatch.quantity += 1;
                        if (image && image !== 'undefined' && image !== 'null') {
                            itemMatch.image = image;
                        }
                    } else {
                        cart.push({ id, title, price, image, quantity: 1 });
                    }

                    localStorage.setItem('sb_cart', JSON.stringify(cart));
                    renderCart();
                    openCart();
                    return;
                }

                // 2. INCREASE QUANTITY ACTION
                if (target.classList.contains('increase-qty') || target.closest('.increase-qty')) {
                    const cart = JSON.parse(localStorage.getItem('sb_cart') || '[]');
                    const btn = target.classList.contains('increase-qty') ? target : target.closest('.increase-qty');
                    const id = btn.dataset.id;
                    
                    const item = cart.find(i => i.id === id);
                    if (item) {
                        item.quantity += 1;
                        localStorage.setItem('sb_cart', JSON.stringify(cart));
                        renderCart();
                    }
                    return;
                }

                // 3. DECREASE QUANTITY ACTION
                if (target.classList.contains('decrease-qty') || target.closest('.decrease-qty')) {
                    const cart = JSON.parse(localStorage.getItem('sb_cart') || '[]');
                    const btn = target.classList.contains('decrease-qty') ? target : target.closest('.decrease-qty');
                    const id = btn.dataset.id;
                    
                    const matchIndex = cart.findIndex(i => i.id === id);
                    if (matchIndex > -1) {
                        if (cart[matchIndex].quantity > 1) {
                            cart[matchIndex].quantity -= 1;
                        } else {
                            cart.splice(matchIndex, 1);
                        }
                        localStorage.setItem('sb_cart', JSON.stringify(cart));
                        renderCart();
                    }
                    return;
                }

                // 4. TRASH REMOVAL ACTION
                if (target.classList.contains('remove-item') || target.closest('.remove-item')) {
                    const cart = JSON.parse(localStorage.getItem('sb_cart') || '[]');
                    const btn = target.classList.contains('remove-item') ? target : target.closest('.remove-item');
                    const id = btn.dataset.id;
                    
                    const updatedCart = cart.filter(i => i.id !== id);
                    localStorage.setItem('sb_cart', JSON.stringify(updatedCart));
                    renderCart();
                    return;
                }
            });

            window.cartListenersInitialized = true;
        }

        document.getElementById('checkoutBtn')?.addEventListener('click', () => {
            const cart = JSON.parse(localStorage.getItem('sb_cart') || '[]');
            if (cart.length === 0) return;

            const shopifyDomain = 'sb-floristry.myshopify.com';
            
            const lines = cart.map(item => {
                let numericId = item.id;
                if (numericId.includes('gid://shopify/ProductVariant/')) {
                    numericId = numericId.split('/').pop();
                } else {
                    try {
                        const base64Decoded = atob(numericId);
                        if (base64Decoded.includes('gid://shopify/ProductVariant/')) {
                            numericId = base64Decoded.split('/').pop();
                        }
                    } catch (err) {}
                }
                return `${numericId}:${item.quantity}`;
            }).join(',');

            const deliveryDateVal = document.getElementById('cartDeliveryDate')?.value || '';
            const giftMessageVal = document.getElementById('cartGiftMessage')?.value || '';

            let checkoutUrl = `https://${shopifyDomain}/cart/${lines}`;
            const params = [];
            if (giftMessageVal) {
                params.push(`note=${encodeURIComponent("Gift Message: " + giftMessageVal)}`);
            }
            if (deliveryDateVal) {
                params.push(`attributes[Delivery-Date]=${encodeURIComponent(deliveryDateVal)}`);
            }

            if (params.length > 0) {
                checkoutUrl += `?${params.join('&')}`;
            }

            window.location.href = checkoutUrl;
        });

        renderCart();
    });
</script>
