---
// src/components/Header.astro
---
<header class="fixed w-full z-50 transition-all duration-300 bg-white/95 backdrop-blur-sm border-b border-gray-100" id="main-header">
  
  <!-- Announcement Bar -->
  <div class="bg-sb-black text-sb-gold py-2 text-center text-[10px] uppercase tracking-luxury font-bold px-4">
    Free Local Essex Delivery on Orders Over £60
  </div>

  <!-- Main Navigation -->
  <div class="container mx-auto px-6 h-20 flex items-center justify-between">

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="md:hidden text-sb-black text-xl focus:outline-none">
      <i class="fas fa-bars"></i>
    </button>

    <!-- Left Nav (Desktop) -->
    <nav class="hidden md:flex items-center space-x-8 w-1/3">
      <a href="/collections/seasonal" class="text-xs uppercase tracking-luxury font-bold text-sb-black hover:text-sb-gold transition-colors">Shop</a>
      <a href="/occasion-finder" class="text-xs uppercase tracking-luxury font-bold text-sb-black hover:text-sb-gold transition-colors flex items-center"><i class="fas fa-magic mr-1.5 text-sb-gold"></i> Gift Finder</a>
      <a href="/subscriptions" class="text-xs uppercase tracking-luxury font-bold text-sb-black hover:text-sb-gold transition-colors">Subscriptions</a>
    </nav>

    <!-- Logo (Center) -->
    <div class="w-1/3 flex justify-center">
      <a href="/" class="block">
        <img src="/images/logo.png" alt="SB Floristry" class="h-10 md:h-12 object-contain mx-auto" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
        <h1 class="hidden font-serif text-3xl font-light text-sb-black tracking-widest text-center">SB<br/><span class="text-[10px] tracking-luxury uppercase font-bold block mt-1">Floristry</span></h1>
      </a>
    </div>

    <!-- Right Nav (Desktop) & Cart -->
    <div class="flex items-center justify-end space-x-6 md:space-x-8 w-1/3">
      <nav class="hidden md:flex items-center space-x-8">
        <a href="/weddings" class="text-xs uppercase tracking-luxury font-bold text-sb-black hover:text-sb-gold transition-colors">Weddings</a>
        <a href="/funerals" class="text-xs uppercase tracking-luxury font-bold text-sb-black hover:text-sb-gold transition-colors">Sympathy</a>
      </nav>
      
      <!-- Cart Toggle Button -->
      <button id="cart-open-btn" class="text-sb-black hover:text-sb-gold transition-colors relative flex items-center focus:outline-none">
        <span class="text-xs uppercase tracking-luxury font-bold mr-2 hidden md:block">Cart</span>
        <i class="fas fa-shopping-bag text-lg md:text-xl"></i>
        <span id="cart-count" class="absolute -top-1.5 -right-2 md:-right-2.5 bg-sb-gold text-sb-black text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center hidden">0</span>
      </button>
    </div>

  </div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="fixed inset-0 bg-white z-40 transform -translate-x-full transition-transform duration-300 md:hidden flex flex-col pt-24 px-8 pb-8 overflow-y-auto">
    <button id="close-mobile-menu" class="absolute top-6 right-6 text-2xl text-sb-black focus:outline-none">
      <i class="fas fa-times"></i>
    </button>
    <nav class="flex flex-col space-y-6 text-center mt-8">
      <a href="/collections/seasonal" class="text-lg font-serif text-sb-black hover:text-sb-gold">Shop Collections</a>
      <a href="/occasion-finder" class="text-lg font-serif text-sb-black hover:text-sb-gold flex items-center justify-center"><i class="fas fa-magic mr-2 text-sb-gold text-sm"></i> Gift Finder</a>
      <a href="/subscriptions" class="text-lg font-serif text-sb-black hover:text-sb-gold flex items-center justify-center"><i class="fas fa-calendar-alt mr-2 text-sb-gold text-sm"></i> Subscriptions</a>
      
      <div class="w-12 h-px bg-gray-200 mx-auto my-4"></div>
      
      <a href="/weddings" class="text-lg font-serif text-sb-black hover:text-sb-gold">Weddings</a>
      <a href="/funerals" class="text-lg font-serif text-sb-black hover:text-sb-gold">Sympathy</a>
      <a href="/our-story" class="text-lg font-serif text-sb-black hover:text-sb-gold">Our Story</a>
      <a href="/contact" class="text-lg font-serif text-sb-black hover:text-sb-gold">Contact</a>
    </nav>
  </div>
</header>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const header = document.getElementById('main-header');
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('close-mobile-menu');
    const mobileMenu = document.getElementById('mobile-menu');
    
    // Check if cart logic relies on specific class or id, keeping generic open functionality
    const cartOpenBtn = document.getElementById('cart-open-btn');
    const cartModal = document.getElementById('cart-modal');

    // Scroll effect
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.classList.add('shadow-md');
      } else {
        header.classList.remove('shadow-md');
      }
    });

    // Mobile Menu Toggle
    if(mobileBtn && closeBtn && mobileMenu) {
      mobileBtn.addEventListener('click', () => {
        mobileMenu.classList.remove('-translate-x-full');
      });
      closeBtn.addEventListener('click', () => {
        mobileMenu.classList.add('-translate-x-full');
      });
    }

    // Connect Header Cart Button to existing CartModal if present
    if (cartOpenBtn && cartModal) {
      cartOpenBtn.addEventListener('click', () => {
        cartModal.classList.remove('translate-x-full');
        document.body.style.overflow = 'hidden';
      });
    }
  });
</script>
