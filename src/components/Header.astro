---
import { shopifyFetch } from '../utils/shopify.js';

// 1. Fetch all unique tags from Shopify at build time
const tagsQuery = `
  {
    products(first: 250) {
      edges {
        node {
          tags
        }
      }
    }
  }
`;
const response = await shopifyFetch({ query: tagsQuery });
const products = response?.data?.products?.edges || [];

// 2. Extract and clean the tags
const allTags = new Set();
// Highlight-add: 'corporate' added to ignored tags
const ignoredTags = ['subscription', 'bespoke', 'add-on', 'upsell', 'white', 'red', 'pink', 'corporate', 'hotels', 'spas', 'wellness'];
products.forEach((edge) => {
  edge.node.tags.forEach((tag) => {
    const cleanTag = tag.trim();
    if (!ignoredTags.includes(cleanTag.toLowerCase())) {
      allTags.add(cleanTag);
    }
  });
});

// Convert set to a sorted array
const dynamicTags = Array.from(allTags).sort();
