---
// src/components/Footer.astro
const year = new Date().getFullYear();
---
<footer class="bg-sb-black text-white pt-20 pb-10 border-t border-white/10">
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <!-- Brand Details -->
      <div>
        <img src="/images/logo.png" alt="SB Floristry" class="h-10 object-contain mb-6 filter invert brightness-0" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
        <h2 class="hidden font-serif text-2xl mb-6 text-sb-cream">SB Floristry</h2>
        <p class="text-gray-400 text-sm font-light leading-relaxed mb-6">
          Luxury floral design based in Essex. We specialize in bespoke arrangements, elegant weddings, and beautiful everyday gifting.
        </p>
        <div class="flex space-x-4">
          <a href="#" class="text-white hover:text-sb-gold transition-colors"><i class="fab fa-instagram text-xl"></i></a>
          <a href="#" class="text-white hover:text-sb-gold transition-colors"><i class="fab fa-facebook-f text-xl"></i></a>
          <a href="#" class="text-white hover:text-sb-gold transition-colors"><i class="fab fa-pinterest-p text-xl"></i></a>
        </div>
      </div>

      <!-- Shop & Gift Links -->
      <div>
        <h3 class="text-[10px] tracking-luxury uppercase font-bold text-sb-gold mb-6">Shop & Gift</h3>
        <ul class="space-y-4 text-sm font-light text-gray-300">
          <li><a href="/collections/seasonal" class="hover:text-white transition-colors">The Seasonal Edit</a></li>
          <li><a href="/collections/signature" class="hover:text-white transition-colors">Signature Collection</a></li>
          <li><a href="/occasion-finder" class="hover:text-sb-gold transition-colors flex items-center"><i class="fas fa-magic mr-2 text-sb-gold text-xs"></i> AI Advisor</a></li>
          <li><a href="/subscriptions" class="hover:text-sb-gold transition-colors flex items-center"><i class="fas fa-calendar-alt mr-2 text-sb-gold text-xs"></i> Subscriptions</a></li>
        </ul>
      </div>

      <!-- Services & Info Links -->
      <div>
        <h3 class="text-[10px] tracking-luxury uppercase font-bold text-sb-gold mb-6">Services & Info</h3>
        <ul class="space-y-4 text-sm font-light text-gray-300">
          <li><a href="/weddings" class="hover:text-white transition-colors">Weddings & Events</a></li>
          <li><a href="/funerals" class="hover:text-white transition-colors">Sympathy Flowers</a></li>
          <li><a href="/our-story" class="hover:text-white transition-colors">Our Story</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact Us</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="text-[10px] tracking-luxury uppercase font-bold text-sb-gold mb-6">Join The Club</h3>
        <p class="text-gray-400 text-sm font-light mb-4">Subscribe for 10% off your first luxury order, plus seasonal updates and exclusive event invites.</p>
        <form class="flex border-b border-gray-600 pb-2 focus-within:border-sb-gold transition-colors">
          <input type="email" placeholder="Email Address" class="bg-transparent w-full focus:outline-none text-sm text-white placeholder-gray-500" required />
          <button type="submit" class="text-sb-gold hover:text-white transition-colors text-xs uppercase tracking-luxury font-bold">Join</button>
        </form>
      </div>

    </div>

    <!-- Copyright & Legal -->
    <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-xs text-gray-500 font-light mb-4 md:mb-0">
        &copy; {year} SB Floristry. All rights reserved.
      </p>
      <div class="flex space-x-6 text-xs text-gray-500 font-light">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
        <a href="#" class="hover:text-white transition-colors">Refund Policy</a>
      </div>
    </div>
  </div>
</footer>
