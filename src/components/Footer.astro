---
// src/components/Footer.astro
const year = new Date().getFullYear();
---
<footer class="bg-sb-black text-sb-cream pt-16 pb-8 border-t border-white/5 relative z-10">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col items-center text-center mb-12">
            <!-- Footer Logo Circle - Fixed visibility by using a dark premium background and delicate gold border -->
            <a href="/" class="w-24 h-24 rounded-full bg-[#111111] border border-sb-gold/30 flex items-center justify-center mb-6 hover:scale-105 transition-all duration-300 shadow-xl shadow-black/40 group">
                <img src="/images/logo.png" alt="SB Floristry Logo" class="h-14 w-auto object-contain group-hover:rotate-3 transition-transform duration-500" />
            </a>
            <p class="font-serif text-xl text-sb-gold font-light tracking-wide">SB Floristry</p>
            <p class="text-xs text-gray-400 mt-2 max-w-sm font-light leading-relaxed">Bespoke floral design for weddings, events, funerals, and daily luxury arrangements across Essex.</p>
        </div>

        <!-- Footer Grid Links -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 py-8 border-t border-b border-white/5 text-center md:text-left">
            <div>
                <h4 class="font-serif text-sm uppercase tracking-[0.2em] text-sb-gold mb-4">Our Collections</h4>
                <ul class="space-y-2 text-xs text-gray-400 font-light">
                    <li><a href="/collections/signature" class="hover:text-sb-gold transition-colors">The Signature Collection</a></li>
                    <li><a href="/collections/seasonal" class="hover:text-sb-gold transition-colors">Seasonal Creations</a></li>
                    <li><a href="/subscriptions" class="hover:text-sb-gold transition-colors">Floral Subscriptions</a></li>
                    <li><a href="/occasion-finder" class="hover:text-sb-gold transition-colors">Occasion Finder</a></li>
                </ul>
            </div>

            <div>
                <h4 class="font-serif text-sm uppercase tracking-[0.2em] text-sb-gold mb-4">Bespoke Services</h4>
                <ul class="space-y-2 text-xs text-gray-400 font-light">
                    <li><a href="/weddings" class="hover:text-sb-gold transition-colors">Weddings & Bridal</a></li>
                    <li><a href="/funerals" class="hover:text-sb-gold transition-colors">Funeral Tributes</a></li>
                    <li><a href="/contact" class="hover:text-sb-gold transition-colors">Corporate & Events</a></li>
                </ul>
            </div>

            <div>
                <h4 class="font-serif text-sm uppercase tracking-[0.2em] text-sb-gold mb-4">Customer Care</h4>
                <ul class="space-y-2 text-xs text-gray-400 font-light">
                    <li><a href="/contact" class="hover:text-sb-gold transition-colors">Get In Touch</a></li>
                    <li><a href="/contact#delivery" class="hover:text-sb-gold transition-colors">Delivery Information</a></li>
                    <li><a href="/contact#faqs" class="hover:text-sb-gold transition-colors">Frequently Asked Questions</a></li>
                </ul>
            </div>

            <div>
                <h4 class="font-serif text-sm uppercase tracking-[0.2em] text-sb-gold mb-4">Connect With Us</h4>
                <p class="text-xs text-gray-400 mb-4 font-light leading-relaxed">Stay updated with our latest floral designs, news, and seasonal highlights from our Essex workshop.</p>
                <div class="flex justify-center md:justify-start gap-4 text-gray-400">
                    <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="hover:text-sb-gold transition-colors" aria-label="Follow us on Instagram">
                        <i class="fab fa-instagram text-lg"></i>
                    </a>
                    <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="hover:text-sb-gold transition-colors" aria-label="Follow us on Facebook">
                        <i class="fab fa-facebook-f text-lg"></i>
                    </a>
                    <a href="https://pinterest.com" target="_blank" rel="noopener noreferrer" class="hover:text-sb-gold transition-colors" aria-label="Follow us on Pinterest">
                        <i class="fab fa-pinterest-p text-lg"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Footer Bottom Bar -->
        <div class="flex flex-col sm:flex-row items-center justify-between pt-8 text-[10px] text-gray-500 font-light tracking-wider uppercase">
            <p>&copy; {new Date().getFullYear()} SB Floristry. All Rights Reserved.</p>
            <p class="mt-2 sm:mt-0">Website by <a href="https://jsofficesolutions.com" target="_blank" rel="noopener noreferrer" class="hover:text-sb-gold transition-colors">JS Office Solutions</a></p>
        </div>
    </div>
</footer>
