---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

// Reusing the signature image or substituting a corporate-focused entry image if needed.
// For continuity with existing assets, we point to the signature asset or a dedicated hero placeholder.
import corporateHeroImg from '../../../public/images/collection-signature.jpg';

const corporateSectors = [
  {
    title: "Hotels & Hospitality",
    description: "Grand lobby installations, reception styling, and seasonal atmospheric enhancements curated for elite boutique and luxury hotels.",
    link: "/corporate/hotels",
    icon: "fa-hotel",
    cta: "Explore Hotel Styling"
  },
  {
    title: "Spas & Wellness",
    description: "Tranquil, minimalist floral art and calming botanical installations designed to heighten sensory relaxation in premium wellness retreats.",
    link: "/corporate/spas-wellness",
    icon: "fa-spa",
    cta: "Explore Wellness Styling"
  },
  {
    title: "Corporate Events",
    description: "Bespoke tablescapes, stage arrangements, and branded launch installations tailored to translate corporate identity into living art.",
    link: "/corporate/events",
    icon: "fa-handshake",
    cta: "Explore Event Floristry"
  }
];
---

<Layout 
  title="Luxury Corporate Floristry & Installations" 
  description="SB Floristry: Elite corporate floral contracts, weekly office rotations, and bespoke high-end installation styling across Essex and London."
>
  <section class="relative h-[75vh] overflow-hidden">
      <div class="absolute inset-0">
          <Image 
            src={corporateHeroImg} 
            alt="SB Floristry Luxury Corporate Floral Installation" 
            class="w-full h-full object-cover hero-zoom opacity-40" 
            loading="eager"
            quality="high"
            style="object-position: center 40%;"
          />
          <div class="absolute inset-0 bg-black/70"></div>
          <div class="absolute bottom-0 left-0 w-full h-1/3 bg-gradient-to-t from-sb-black to-transparent"></div>
      </div>
      <div class="relative z-10 container mx-auto px-6 h-full flex flex-col justify-center items-center text-center text-sb-cream pt-20">
          <span class="text-xs md:text-sm tracking-[0.3em] uppercase mb-6 font-medium text-sb-gold animate-fade-in">Corporate Accounts & Spatial Design</span>
          <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl mb-8 leading-none animate-fade-in-up font-normal">
              Elevate Your <br><span class="italic font-light text-gold-metallic">Brand Space</span>
          </h1>
          <p class="max-w-xl text-gray-300 font-light text-base md:text-lg mb-10 animate-fade-in delay-200">
              Bespoke commercial contracts, permanent botanical architecture, and weekly residential corporate rotations tailored to London & Essex venues.
          </p>
          <a href="#sectors-section" class="animate-fade-in btn-luxury border border-sb-cream/30 text-sb-cream px-10 py-3 uppercase tracking-luxury text-xs font-bold hover:border-sb-gold">
              Explore Sectors
          </a>
      </div>
  </section>

  <section class="py-24 bg-sb-black text-sb-cream relative border-t border-white/5">
      <div class="container mx-auto px-6 text-center max-w-3xl">
          <span class="text-gold-metallic text-2xl mb-6 block reveal"><i class="fas fa-building"></i></span>
          <h2 class="font-serif text-4xl md:text-5xl text-sb-cream mb-8 reveal font-light text-shadow-sm">Botanical Identity</h2>
          <p class="text-gray-400 leading-relaxed text-lg md:text-xl font-light mb-12 reveal">
              At SB Floristry, we recognize that flowers form a vital element of your brand's physical language. Guided by our mother-and-daughter creative vision, we partner alongside luxury brands, asset management groups, and heritage hoteliers to transform corporate spaces into unforgettable botanical landmarks.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-xs font-bold tracking-luxury text-sb-cream uppercase reveal pt-6 border-t border-white/5">
              <div class="flex items-center justify-center py-2"><i class="fas fa-calendar-alt mr-3 text-sb-gold"></i> Weekly Office Rotations</div>
              <div class="flex items-center justify-center py-2"><i class="fas fa-eye mr-3 text-sb-gold"></i> Site Consultation</div>
              <div class="flex items-center justify-center py-2"><i class="fas fa-shield-alt mr-3 text-sb-gold"></i> Dedicated Account Lead</div>
          </div>
      </div>
  </section>

  <section id="sectors-section" class="py-24 bg-sb-cream">
    <div class="container mx-auto px-6">
        <div class="text-center mb-20 reveal">
            <h3 class="font-serif text-5xl text-sb-black mb-4 font-light">Commercial Expertise</h3>
            <p class="text-xs text-gray-500 tracking-luxury uppercase">Tailored solutions for luxury industries</p>
            <div class="w-16 h-px bg-sb-gold mx-auto mt-6"></div>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8" id="corporate-sectors-grid">
            {corporateSectors.map((sector) => (
                <div class="bg-white border border-gray-100 p-10 flex flex-col justify-between items-center text-center shadow-sm hover:shadow-xl transition-all duration-500 reveal group">
                    <div class="flex flex-col items-center">
                        <div class="w-16 h-16 bg-sb-black rounded-full flex items-center justify-center text-sb-gold mb-8 group-hover:bg-sb-gold group-hover:text-sb-black transition-colors duration-500">
                            <i class={`fas ${sector.icon} text-xl`}></i>
                        </div>
                        <h4 class="font-serif text-3xl text-sb-black mb-4 font-light">{sector.title}</h4>
                        <p class="text-gray-500 font-light text-sm leading-relaxed mb-8 max-w-sm">
                            {sector.description}
                        </p>
                    </div>
                    
                    <a 
                      href={sector.link} 
                      class="inline-block w-full border border-sb-black text-sb-black py-3 px-6 text-[10px] font-bold uppercase tracking-luxury hover:bg-sb-black hover:text-sb-cream transition-all duration-500"
                    >
                      {sector.cta}
                    </a>
                </div>
            ))}
        </div>
    </div>
  </section>

  <section class="py-24 bg-sb-black text-sb-cream border-t border-white/5" id="corporate-contact-section">
      <div class="container mx-auto px-6 max-w-4xl">
          <div class="text-center mb-16 reveal">
              <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-4 block"><i class="fas fa-paper-plane mr-2"></i> Corporate Enquiries</span>
              <h3 class="font-serif text-5xl md:text-6xl text-sb-cream mb-4 font-light">Initiate A Contract</h3>
              <p class="font-light text-gray-400 text-lg">Arrange a visual site inspection or custom installation proposal.</p>
          </div>
          
          <form id="home-contact-form" class="space-y-8 reveal">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-name">Company Name</label>
                      <input type="text" id="contact-name" name="company-name" required class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream placeholder-gray-600 text-base">
                  </div>
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-email">Corporate Email</label>
                      <input type="email" id="contact-email" name="email" required class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream placeholder-gray-600 text-base">
                  </div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-phone">Direct Phone</label>
                      <input type="tel" id="contact-phone" name="phone" required class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream text-base">
                  </div>
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-interest">Primary Sector</label>
                      <select id="contact-interest" name="interest" class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream text-base">
                          <option value="Hotels" class="bg-sb-black text-white">Hotels & Hospitality</option>
                          <option value="Spas" class="bg-sb-black text-white">Spas & Wellness</option>
                          <option value="Events" class="bg-sb-black text-white">Corporate Events</option>
                          <option value="Weekly Accounts" class="bg-sb-black text-white">Weekly Office Contracts</option>
                      </select>
                  </div>
              </div>
              <div class="space-y-1">
                  <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-message">Design Brief / Spatial Scope</label>
                  <textarea id="contact-message" name="message" rows="4" required placeholder="Outline your spatial dimensions, frequency needs, or installation dates..." class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream placeholder-gray-600 text-base"></textarea>
              </div>
              <div class="text-center pt-8">
                  <button type="submit" class="btn-luxury border border-sb-cream text-sb-cream px-16 py-4 uppercase tracking-luxury text-xs font-bold inline-block">
                      Submit Corporate Brief
                  </button>
              </div>
          </form>
      </div>
  </section>
</Layout>
