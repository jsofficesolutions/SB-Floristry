---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

// Reusing existing imagery to keep within asset bounds or pointing to a tranquil placeholder
import wellnessHeroImg from '../../../public/images/collection-signature.jpg';

const wellnessOfferings = [
  {
    title: "Tranquil Treatment Suites",
    description: "Minimalist, life-giving arrangements utilizing calming white orchids, architectural eucalyptus, and soft textures designed to reinforce sensory relaxation.",
    icon: "fa-spa"
  },
  {
    title: "Hydrotherapy & Lounge Spaces",
    description: "Moisture-tolerant botanical installations, living green walls, and elegant stone-placed arrangements that thrive in high-humidity luxury environments.",
    icon: "fa-water"
  },
  {
    title: "Aromatic Consultations",
    description: "Curated pairings of structural florals with live aromatic herbs like lavender, rosemary, and mint to elevate the olfactory signature of your wellness retreat." ,
    icon: "fa-wind"
  }
];
---

<Layout 
  title="Luxury Spa & Wellness Floristry" 
  description="SB Floristry: Minimalist botanical art and calming floral installations tailored for premium wellness retreats, spas, and luxury treatment centers across London and Essex."
>
  <section class="relative h-[65vh] overflow-hidden">
      <div class="absolute inset-0">
          <Image 
            src={wellnessHeroImg} 
            alt="SB Floristry Luxury Spa & Wellness Floral Installation" 
            class="w-full h-full object-cover hero-zoom opacity-40" 
            loading="eager"
            quality="high"
            style="object-position: center 60%;"
          />
          <div class="absolute inset-0 bg-black/75"></div>
          <div class="absolute bottom-0 left-0 w-full h-1/3 bg-gradient-to-t from-sb-black to-transparent"></div>
      </div>
      <div class="relative z-10 container mx-auto px-6 h-full flex flex-col justify-center items-center text-center text-sb-cream pt-20">
          <span class="text-xs md:text-sm tracking-[0.3em] uppercase mb-6 font-medium text-sb-gold animate-fade-in">Corporate Accounts · Spas & Wellness</span>
          <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl mb-8 leading-none animate-fade-in-up font-normal">
              Tranquil <br><span class="italic font-light text-gold-metallic">Botanical Art</span>
          </h1>
          <p class="max-w-xl text-gray-300 font-light text-base md:text-lg mb-10 animate-fade-in delay-200">
              Sensory-driven floral architecture and calming botanical arrangements crafted to deepen relaxation in premium wellness environments.
          </p>
          <a href="#offerings-section" class="animate-fade-in btn-luxury border border-sb-cream/30 text-sb-cream px-10 py-3 uppercase tracking-luxury text-xs font-bold hover:border-sb-gold">
              Explore Our Approach
          </a>
      </div>
  </section>

  <section class="py-24 bg-sb-black text-sb-cream relative border-t border-white/5">
      <div class="container mx-auto px-6 text-center max-w-3xl">
          <span class="text-gold-metallic text-2xl mb-6 block reveal"><i class="fas fa-leaf"></i></span>
          <h2 class="font-serif text-4xl md:text-5xl text-sb-cream mb-8 reveal font-light text-shadow-sm">The Living Sanctuary</h2>
          <p class="text-gray-400 leading-relaxed text-lg md:text-xl font-light mb-12 reveal">
              In a luxury wellness space, visual clutter dissolves. We collaborate alongside spa directors and interior architects to introduce minimalist floral styling that respects clean design lines while introducing the grounding, organic energy of nature.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-xs font-bold tracking-luxury text-sb-cream uppercase reveal pt-6 border-t border-white/5">
              <div class="flex items-center justify-center py-2"><i class="fas fa-circle-notch mr-3 text-sb-gold"></i> Minimalist Aesthetics</div>
              <div class="flex items-center justify-center py-2"><i class="fas fa-tint mr-3 text-sb-gold"></i> Humidity-Resilient Choices</div>
              <div class="flex items-center justify-center py-2"><i class="fas fa-seedling mr-3 text-sb-gold"></i> Weekly Rotation Care</div>
          </div>
      </div>
  </section>

  <section id="offerings-section" class="py-24 bg-sb-cream">
    <div class="container mx-auto px-6">
        <div class="text-center mb-20 reveal">
            <h3 class="font-serif text-5xl text-sb-black mb-4 font-light">Spatial Customization</h3>
            <p class="text-xs text-gray-500 tracking-luxury uppercase">Elevating every sensory touchpoint</p>
            <div class="w-16 h-px bg-sb-gold mx-auto mt-6"></div>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            {wellnessOfferings.map((offering) => (
                <div class="bg-white border border-gray-100 p-10 flex flex-col justify-between items-center text-center shadow-sm hover:shadow-xl transition-all duration-500 reveal group">
                    <div class="flex flex-col items-center">
                        <div class="w-16 h-16 bg-sb-black rounded-full flex items-center justify-center text-sb-gold mb-8 group-hover:bg-sb-gold group-hover:text-sb-black transition-colors duration-500">
                            <i class={`fas ${offering.icon} text-xl`}></i>
                        </div>
                        <h4 class="font-serif text-3xl text-sb-black mb-4 font-light">{offering.title}</h4>
                        <p class="text-gray-500 font-light text-sm leading-relaxed mb-4 max-w-sm">
                            {offering.description}
                        </p>
                    </div>
                </div>
            ))}
        </div>
        
        <div class="text-center mt-16 reveal">
            <a href="/corporate" class="inline-block text-xs font-bold tracking-luxury uppercase text-sb-black hover:text-sb-gold transition-colors">
                <i class="fas fa-arrow-left mr-2"></i> Back to Corporate Overview
            </a>
        </div>
    </div>
  </section>

  <section class="py-24 bg-sb-black text-sb-cream border-t border-white/5" id="corporate-contact-section">
      <div class="container mx-auto px-6 max-w-4xl">
          <div class="text-center mb-16 reveal">
              <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-4 block"><i class="fas fa-paper-plane mr-2"></i> Spa Accounts</span>
              <h3 class="font-serif text-5xl md:text-6xl text-sb-cream mb-4 font-light">Design Consultation</h3>
              <p class="font-light text-gray-400 text-lg">Arrange a visual site inspection or bespoke sensory botanical proposal.</p>
          </div>
          
          <form id="home-contact-form" class="space-y-8 reveal">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-name">Company Name</label>
                      <input type="text" id="contact-name" name="company-name" required class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream placeholder-gray-600 text-base">
                  </div>
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-email">Corporate Email</label>
                      <input type="email" id="contact-email" name="email" required class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream placeholder-gray-600 text-base">
                  </div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-phone">Direct Phone</label>
                      <input type="tel" id="contact-phone" name="phone" required class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream text-base">
                  </div>
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-interest">Primary Sector</label>
                      <select id="contact-interest" name="interest" class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream text-base">
                          <option value="Spas" selected class="bg-sb-black text-white">Spas & Wellness</option>
                          <option value="Hotels" class="bg-sb-black text-white">Hotels & Hospitality</option>
                          <option value="Events" class="bg-sb-black text-white">Corporate Events</option>
                          <option value="Weekly Accounts" class="bg-sb-black text-white">Weekly Office Contracts</option>
                      </select>
                  </div>
              </div>
              <div class="space-y-1">
                  <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-message">Design Brief / Spatial Scope</label>
                  <textarea id="contact-message" name="message" rows="4" required placeholder="Outline your treatment zones, humidity conditions, frequency needs, or installation dates..." class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream placeholder-gray-600 text-base"></textarea>
              </div>
              <div class="text-center pt-8">
                  <button type="submit" class="btn-luxury border border-sb-cream text-sb-cream px-16 py-4 uppercase tracking-luxury text-xs font-bold inline-block">
                      Submit Corporate Brief
                  </button>
              </div>
          </form>
      </div>
  </section>
</Layout>
