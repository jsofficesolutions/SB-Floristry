---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

// Reusing existing high-end image assets or placeholders for seamless integration
import hotelHeroImg from '../../../public/images/collection-weddings.jpg'; 
import lobbyImg from '../../../public/images/gallery-1.jpg';
import suiteImg from '../../../public/images/gallery-2.jpg';
import dynamicImg from '../../../public/images/gallery-3.jpg';

const features = [
  {
    title: "Lobby & Reception Architecture",
    description: "Grand scale focal arrangements and structural botanical styling meticulously planned to enhance structural sightlines and reflect elite heritage branding."
  },
  {
    title: "Weekly Rotation Management",
    description: "Discreet mid-week refreshes and complete routine rotations scheduled outside guest-facing operational peaks to sustain continuous premium aesthetics."
  },
  {
    title: "VIP Suites & Turn-Down Floristry",
    description: "Intimate, tailored vignettes and bespoke botanical accents curated matching individual guest preferences for high-profile presidential stays."
  }
];

const gallery = [
  { src: lobbyImg, alt: "Luxury Hotel Lobby Installation" },
  { src: suiteImg, alt: "Presidential Suite Floral Accents" },
  { src: dynamicImg, alt: "Fine Dining Spatial Floristry Layout" }
];
---

<Layout 
  title="Luxury Hotel & Hospitality Floristry Contracts" 
  description="SB Floristry: Bespoke corporate floral agreements, permanent architecture, and striking weekly rotations for boutique and luxury hoteliers in London and Essex."
>
  <section class="relative h-[65vh] overflow-hidden">
      <div class="absolute inset-0">
          <Image 
            src={hotelHeroImg} 
            alt="SB Floristry Luxury Hotel Floral Installation" 
            class="w-full h-full object-cover hero-zoom opacity-40" 
            loading="eager"
            quality="high"
            style="object-position: center 35%;"
          />
          <div class="absolute inset-0 bg-black/75"></div>
          <div class="absolute bottom-0 left-0 w-full h-1/3 bg-gradient-to-t from-sb-black to-transparent"></div>
      </div>
      <div class="relative z-10 container mx-auto px-6 h-full flex flex-col justify-center items-center text-center text-sb-cream pt-16">
          <a href="/corporate" class="text-xs tracking-luxury uppercase mb-4 text-sb-gold hover:text-sb-cream transition-colors duration-300">
              <i class="fas fa-arrow-left mr-2 text-[10px]"></i> Back to Corporate
          </a>
          <span class="text-xs md:text-sm tracking-[0.3em] uppercase mb-6 font-medium text-sb-gold/80 animate-fade-in">Hospitality Portfolio</span>
          <h1 class="font-serif text-4xl md:text-6xl lg:text-7xl mb-6 leading-none animate-fade-in-up font-normal">
              Hotels & <span class="italic font-light text-gold-metallic">Hospitality</span>
          </h1>
          <p class="max-w-2xl text-gray-400 font-light text-sm md:text-base mb-0 animate-fade-in delay-200">
              Transforming grand commercial spaces into seasonal, atmospheric landmarks. We coordinate alongside heritage hoteliers and luxury guest experiences across Essex and London.
          </p>
      </div>
  </section>

  <section class="py-24 bg-sb-cream text-sb-black">
      <div class="container mx-auto px-6">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
              <div class="reveal">
                  <span class="text-xs text-gray-500 tracking-luxury uppercase mb-3 block">Immersive Atmosphere</span>
                  <h2 class="font-serif text-4xl md:text-5xl text-sb-black mb-8 font-light">The Physical Language of Luxury</h2>
                  <div class="w-12 h-px bg-sb-gold mb-8"></div>
                  <p class="text-gray-600 font-light leading-relaxed mb-6">
                      First impressions within modern hospitality are multi-sensory. At SB Floristry, our mother-and-daughter creative direction styles botanical statements that align flawlessly with your architectural properties, interior themes, and brand tone.
                  </p>
                  <p class="text-gray-600 font-light leading-relaxed mb-8">
                      From towering, minimalist column pieces that anchor grand historic entranceways to elegant accents structuring fine-dining tablescapes, we handle every detail with elite technical expertise and total discretion.
                  </p>
                  <a href="#hotel-contact" class="inline-block border border-sb-black text-sb-black py-3 px-8 text-xs font-bold uppercase tracking-luxury hover:bg-sb-black hover:text-sb-cream transition-all duration-500">
                      Request Consultation
                  </a>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 reveal">
                  {gallery.slice(0, 2).map((item, index) => (
                      <div class={`overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 ${index === 1 ? 'md:translate-y-8' : ''}`}>
                          <Image 
                            src={item.src} 
                            alt={item.alt} 
                            class="w-full h-[400px] object-cover hover:scale-105 transition-transform duration-700"
                          />
                      </div>
                  ))}
              </div>
          </div>
      </div>
  </section>

  <section class="py-24 bg-sb-black text-sb-cream relative border-t border-white/5">
      <div class="container mx-auto px-6">
          <div class="text-center mb-20 reveal">
              <h3 class="font-serif text-4xl md:text-5xl text-sb-cream mb-4 font-light">Custom Operations</h3>
              <p class="text-xs text-sb-gold tracking-luxury uppercase font-semibold">Our structural service scope</p>
              <div class="w-16 h-px bg-sb-gold mx-auto mt-6"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-12 max-w-6xl mx-auto">
              {features.map((feat) => (
                  <div class="border-l border-white/10 pl-8 py-4 reveal hover:border-sb-gold transition-colors duration-500">
                      <h4 class="font-serif text-2xl text-sb-cream mb-4 font-normal">{feat.title}</h4>
                      <p class="text-gray-400 font-light text-sm leading-relaxed">
                          {feat.description}
                      </p>
                  </div>
              ))}
          </div>
      </div>
  </section>

  <section class="py-24 bg-sb-cream">
      <div class="container mx-auto px-6 max-w-5xl text-center">
          <div class="reveal mb-12">
              <span class="text-xs text-gray-500 tracking-luxury uppercase mb-3 block">Visual Portfolio</span>
              <h3 class="font-serif text-3xl md:text-4xl text-sb-black font-light">Curated Hospitality Architecture</h3>
          </div>
          <div class="w-full h-[50vh] overflow-hidden reveal shadow-md">
              <Image 
                src={dynamicImg} 
                alt="Elite Fine Dining Hospitality Floristry" 
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000"
                style="object-position: center 60%;"
              />
          </div>
      </div>
  </section>

  <section class="py-24 bg-sb-black text-sb-cream border-t border-white/5" id="hotel-contact">
      <div class="container mx-auto px-6 max-w-4xl">
          <div class="text-center mb-16 reveal">
              <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-4 block">
                  <i class="fas fa-hotel mr-2"></i> Hospitality Inquiries
              </span>
              <h3 class="font-serif text-4xl md:text-5xl text-sb-cream mb-4 font-light">Partner With Us</h3>
              <p class="font-light text-gray-400 text-base max-w-xl mx-auto">
                  Arrange a confidential layout inspection, schedule visual testing, or secure a custom seasonal installation tender.
              </p>
          </div>
          
          <form id="home-contact-form" class="space-y-8 reveal">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-name">Hotel / Venue Name</label>
                      <input type="text" id="contact-name" name="company-name" required class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream placeholder-gray-600 text-base">
                  </div>
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-email">Corporate Email</label>
                      <input type="email" id="contact-email" name="email" required class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream placeholder-gray-600 text-base">
                  </div>
              </div>
        
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-phone">Direct Phone</label>
                      <input type="tel" id="contact-phone" name="phone" required class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream text-base">
                  </div>
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-interest">Required Service Scope</label>
                      <select id="contact-interest" name="interest" class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream text-base">
                          <option value="Hotels" class="bg-sb-black text-white" selected>Lobby & Reception Installations</option>
                          <option value="Weekly Accounts" class="bg-sb-black text-white">Weekly Hotel Rotations</option>
                          <option value="Suites" class="bg-sb-black text-white">VIP Suite / Fine Dining Styling</option>
                          <option value="Events" class="bg-sb-black text-white">Bespoke Hotel Events & Launches</option>
                      </select>
                  </div>
              </div>
              <div class="space-y-1">
                  <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-message">Design Brief & Brand Scope</label>
                  <textarea id="contact-message" name="message" rows="4" required placeholder="Outline your spatial layout properties, estimated design timelines, or corporate guidelines..." class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream placeholder-gray-600 text-base"></textarea>
              </div>
              <div class="text-center pt-8">
                  <button type="submit" class="btn-luxury border border-sb-cream text-sb-cream px-16 py-4 uppercase tracking-luxury text-xs font-bold inline-block">
                      Submit Hospitality Brief
                  </button>
              </div>
          </form>
      </div>
  </section>
</Layout>
