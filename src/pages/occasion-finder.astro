---
import Layout from '../layouts/Layout.astro';
import { shopifyFetch } from '../utils/shopify.js';

// Fetch all products at build time so the "AI" can access them instantly
const query = `
  {
    products(first: 100) {
      edges {
        node {
          title
          handle
          tags
          priceRange {
            minVariantPrice {
              amount
            }
          }
          images(first: 1) {
            edges {
              node {
                url
              }
            }
          }
        }
      }
    }
  }
`;

const response = await shopifyFetch({ query });
const rawProducts = response?.data?.products?.edges || [];

// Clean up the data to make it easy for our client-side script to filter
const products = rawProducts.map(({ node }) => ({
  title: node.title,
  handle: node.handle,
  tags: node.tags.map(t => t.toLowerCase().trim()),
  price: parseFloat(node.priceRange.minVariantPrice.amount),
  image: node.images.edges[0]?.node?.url || '/images/collection-signature.jpg'
}));
---

<Layout title="AI Gift Concierge | SB Floristry" description="Let our virtual floral concierge find the perfect luxury bouquet for your occasion.">
  
  <!-- Step 1-3 Quiz Background -->
  <section class="min-h-screen bg-sb-cream flex items-center justify-center py-12 px-6 relative" id="quiz-background">
    
    <div class="max-w-4xl w-full bg-white border border-gray-100 shadow-xl p-8 md:p-20 text-center relative overflow-hidden transition-all duration-1000" id="quiz-container">
      
      <!-- Progress Bar -->
      <div class="absolute top-0 left-0 w-full h-1 bg-gray-50" id="progress-container">
        <div class="h-full bg-sb-gold transition-all duration-1000 ease-in-out w-0" id="progress-bar"></div>
      </div>

      <!-- Step 1: Who is it for? -->
      <div class="quiz-step opacity-100 translate-y-0 transition-all duration-700 ease-out" id="step-1">
        <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-6 block"><i class="fas fa-sparkles mr-1"></i> Virtual Concierge</span>
        <h2 class="font-serif text-3xl md:text-5xl text-sb-black mb-10 font-light">Who are we spoiling today?</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto">
          <button class="quiz-btn border border-gray-100 py-6 px-6 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-lg" data-next="step-2">My Partner</button>
          <button class="quiz-btn border border-gray-100 py-6 px-6 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-lg" data-next="step-2">A Friend or Family</button>
          <button class="quiz-btn border border-gray-100 py-6 px-6 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-lg" data-next="step-2">A Colleague / Client</button>
          <button class="quiz-btn border border-gray-100 py-6 px-6 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-lg" data-next="step-2">Treating Myself</button>
        </div>
      </div>

      <!-- Step 2: What's the vibe? -->
      <div class="quiz-step hidden opacity-0 translate-y-4 transition-all duration-700 ease-out" id="step-2">
        <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-6 block">Step 2 of 3</span>
        <h2 class="font-serif text-3xl md:text-5xl text-sb-black mb-10 font-light">What's the overall vibe?</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto">
          <button class="quiz-btn border border-gray-100 py-6 px-6 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-lg" data-next="step-3" data-tag="signature">Romantic & Deep</button>
          <button class="quiz-btn border border-gray-100 py-6 px-6 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-lg" data-next="step-3" data-tag="seasonal">Bright & Fresh</button>
          <button class="quiz-btn border border-gray-100 py-6 px-6 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-lg" data-next="step-3" data-tag="signature">Classic & Elegant</button>
          <button class="quiz-btn border border-gray-100 py-6 px-6 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-lg" data-next="step-3" data-tag="sympathy">Soft & Gentle</button>
        </div>
      </div>

      <!-- Step 3: Budget -->
      <div class="quiz-step hidden opacity-0 translate-y-4 transition-all duration-700 ease-out" id="step-3">
        <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-6 block">Step 3 of 3</span>
        <h2 class="font-serif text-3xl md:text-5xl text-sb-black mb-10 font-light">What is your price range?</h2>
        <div class="flex flex-col gap-5 max-w-md mx-auto">
          <button class="quiz-btn border border-gray-100 py-6 px-6 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-lg finish-quiz" data-min="0" data-max="60">£40 - £60</button>
          <button class="quiz-btn border border-gray-100 py-6 px-6 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-lg finish-quiz" data-min="61" data-max="99">£60 - £100</button>
          <button class="quiz-btn border border-gray-100 py-6 px-6 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-lg finish-quiz" data-min="100" data-max="999">£100+ (Showstopper)</button>
        </div>
      </div>
    </div>
  </section>

  <!-- THE CINEMATIC FULLSCREEN OVERLAY (AI Loading + Results) -->
  <div id="cinematic-overlay" class="fixed inset-0 bg-sb-black z-[100] opacity-0 pointer-events-none transition-opacity duration-1000 flex flex-col items-center justify-center overflow-hidden">
    
    <!-- Ambient Background Lighting & Sparkles -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <!-- Giant soft center glow -->
        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-sb-gold rounded-full opacity-[0.04] blur-[100px]"></div>
        
        <!-- Floating Particles (Pure CSS) -->
        <div class="absolute top-[20%] left-[15%] w-1.5 h-1.5 bg-sb-gold rounded-full animate-pulse opacity-40 blur-[1px]"></div>
        <div class="absolute top-[70%] left-[80%] w-2 h-2 bg-white rounded-full animate-[pulse_4s_ease-in-out_infinite] opacity-30 blur-[2px]"></div>
        <div class="absolute top-[40%] left-[85%] w-1 h-1 bg-sb-gold rounded-full animate-[pulse_3s_ease-in-out_infinite] opacity-50"></div>
        <div class="absolute top-[80%] left-[20%] w-2.5 h-2.5 bg-sb-gold rounded-full animate-pulse opacity-20 blur-[3px]"></div>
    </div>

    <!-- AI Loading View -->
    <div id="ai-loading-view" class="relative z-10 flex flex-col items-center transition-all duration-1000 ease-in-out opacity-100 scale-100 w-full px-6 text-center">
        <!-- Luxurious Glowing Orb -->
        <div class="relative w-40 h-40 mx-auto mb-12 flex items-center justify-center">
            <div class="absolute inset-0 bg-sb-gold rounded-full blur-2xl opacity-20 animate-pulse"></div>
            <div class="absolute inset-0 border-[1px] border-sb-gold/30 rounded-full animate-[spin_6s_linear_infinite]"></div>
            <div class="absolute inset-0 border-[1px] border-sb-gold/15 rounded-full animate-[spin_8s_linear_infinite_reverse] scale-110"></div>
            <i class="fas fa-magic text-4xl text-sb-gold relative z-10 animate-pulse"></i>
        </div>
        
        <h2 class="font-serif text-3xl md:text-4xl text-white mb-4 font-light transition-all duration-1000 ease-in-out transform translate-y-0" id="ai-loading-text">Initializing concierge...</h2>
        <p class="text-sb-gold/70 text-sm font-light uppercase tracking-widest" id="ai-loading-subtext">Please wait</p>
    </div>

    <!-- Final Results View (Strict NO-SCROLL flexbox layout) -->
    <div id="ai-results-view" class="absolute inset-0 z-20 hidden flex-col items-center justify-center p-6 md:p-12 opacity-0 scale-105 transition-all duration-1000">
        
        <!-- Header (Fixed Height) -->
        <div class="text-center shrink-0 mb-6 md:mb-10 w-full">
            <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-3 block"><i class="fas fa-check text-sb-gold mr-2"></i>Curated Selection</span>
            <h2 class="font-serif text-3xl md:text-5xl text-white font-light">Your Perfect Matches</h2>
        </div>
        
        <!-- Compact Grid (Flex-1 ensures it grows but min-h-0 prevents it from pushing content off screen) -->
        <div class="flex-1 min-h-0 w-full max-w-5xl flex flex-col md:flex-row gap-4 md:gap-8" id="results-grid">
            <!-- Products injected here via JS -->
        </div>

        <!-- Footer (Fixed Height) -->
        <div class="shrink-0 mt-6 md:mt-10 pt-6 border-t border-white/10 w-full max-w-xl text-center">
            <button onclick="window.location.reload()" class="text-gray-400 hover:text-sb-gold text-[10px] tracking-luxury uppercase font-bold transition-colors duration-300"><i class="fas fa-redo mr-2"></i> Restart Concierge</button>
        </div>
    </div>

  </div>

  <!-- Pass Shopify products securely to the client -->
  <script id="product-data" type="application/json" set:html={JSON.stringify(products)}></script>

  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      const buttons = document.querySelectorAll('.quiz-btn');
      const progressBar = document.getElementById('progress-bar');
      
      let userPreferences = { tag: 'seasonal', min: 0, max: 999 };

      const loadingPhrases = [
          { main: "Analyzing floral profiles...", sub: "Scanning Essex inventory" },
          { main: "Evaluating seasonal availability...", sub: "Matching colour palettes" },
          { main: "Curating your perfect match...", sub: "Calculating sentiment" },
          { main: "Finalizing recommendations...", sub: "Almost ready" }
      ];

      const productsDataEl = document.getElementById('product-data');
      if(!productsDataEl) return;
      const allProducts = JSON.parse(productsDataEl.innerHTML);

      setTimeout(() => { if(progressBar) progressBar.style.width = '33%'; }, 300);

      // --- Elegant transition for standard steps ---
      function transitionToNextStep(hideId, showId, newProgress) {
          const hideEl = document.getElementById(hideId);
          const showEl = document.getElementById(showId);
          
          hideEl.classList.remove('opacity-100', 'translate-y-0');
          hideEl.classList.add('opacity-0', '-translate-y-4'); 
          
          if(progressBar && newProgress) progressBar.style.width = newProgress;

          setTimeout(() => {
              hideEl.classList.add('hidden');
              hideEl.classList.remove('-translate-y-4');
              hideEl.classList.add('translate-y-4');
              
              showEl.classList.remove('hidden');
              void showEl.offsetWidth; 
              
              showEl.classList.remove('opacity-0', 'translate-y-4');
              showEl.classList.add('opacity-100', 'translate-y-0');
          }, 600);
      }

      buttons.forEach(btn => {
        btn.addEventListener('click', (e) => {
          const clicked = e.currentTarget;
          const currentStepId = clicked.closest('.quiz-step').id;
          
          if(clicked.dataset.tag) userPreferences.tag = clicked.dataset.tag;
          if(clicked.dataset.min) {
              userPreferences.min = parseInt(clicked.dataset.min);
              userPreferences.max = parseInt(clicked.dataset.max);
          }

          // --- TRIGGER FULLSCREEN CINEMATIC FINALE ---
          if (clicked.classList.contains('finish-quiz')) {
            const overlay = document.getElementById('cinematic-overlay');
            const loadingText = document.getElementById('ai-loading-text');
            const loadingSub = document.getElementById('ai-loading-subtext');
            
            // 1. Fade to Black Fullscreen Overlay
            overlay.classList.remove('opacity-0', 'pointer-events-none');
            overlay.classList.add('opacity-100', 'pointer-events-auto');

            // 2. Start text animation
            let phraseIndex = 0;
            
            const interval = setInterval(() => {
                phraseIndex++;
                if(phraseIndex < loadingPhrases.length) {
                    // Glide out
                    loadingText.style.opacity = '0';
                    loadingText.style.transform = 'translateY(10px)';
                    loadingSub.style.opacity = '0';
                    
                    setTimeout(() => {
                        // Update text & glide in
                        loadingText.innerText = loadingPhrases[phraseIndex].main;
                        loadingSub.innerText = loadingPhrases[phraseIndex].sub;
                        loadingText.style.opacity = '1';
                        loadingText.style.transform = 'translateY(0)';
                        loadingSub.style.opacity = '1';
                    }, 1000); 
                } else {
                    clearInterval(interval);
                    showCinematicResults();
                }
            }, 3000); // 3 seconds per cinematic phase

            return;
          }

          // Handle Normal Steps
          const nextStepId = clicked.dataset.next;
          if (nextStepId) {
            let progress = '33%';
            if (nextStepId === 'step-2') progress = '66%';
            if (nextStepId === 'step-3') progress = '100%';
            transitionToNextStep(currentStepId, nextStepId, progress);
          }
        });
      });

      function showCinematicResults() {
          let exactMatches = allProducts.filter(p => 
              p.tags.includes(userPreferences.tag) && 
              p.price >= userPreferences.min && 
              p.price <= userPreferences.max
          );

          if(exactMatches.length === 0) exactMatches = allProducts.filter(p => p.tags.includes(userPreferences.tag));
          if(exactMatches.length === 0) exactMatches = allProducts;

          const perfectMatch = exactMatches[0];

          let upsellMatches = allProducts.filter(p => 
              p.tags.includes(userPreferences.tag) && 
              p.price > perfectMatch.price &&
              p.handle !== perfectMatch.handle
          );
          
          const upsellMatch = upsellMatches.length > 0 ? upsellMatches[0] : allProducts.sort((a,b) => b.price - a.price).find(p => p.handle !== perfectMatch.handle);

          const grid = document.getElementById('results-grid');
          grid.innerHTML = ''; 
          
          if(perfectMatch) grid.innerHTML += createCompactCard(perfectMatch, "The Perfect Match");
          if(upsellMatch) grid.innerHTML += createCompactCard(upsellMatch, "Showstopper Upgrade", true);

          // Elegant Crossfade from Loading to Results
          const loadingView = document.getElementById('ai-loading-view');
          const resultsView = document.getElementById('ai-results-view');

          loadingView.classList.remove('opacity-100', 'scale-100');
          loadingView.classList.add('opacity-0', 'scale-95');

          setTimeout(() => {
              loadingView.classList.add('hidden');
              resultsView.classList.remove('hidden');
              
              // Frame delay forces browser to render 'display: flex' before animating opacity
              requestAnimationFrame(() => {
                  resultsView.classList.remove('opacity-0', 'scale-105');
                  resultsView.classList.add('opacity-100', 'scale-100');
              });
          }, 1000);
      }

      // Compact, No-Scroll Card Design
      function createCompactCard(product, label, isUpsell = false) {
          const badgeClass = isUpsell ? "text-sb-cream bg-white/10 border-white/20" : "text-sb-black bg-sb-gold border-sb-gold";
          const highlightBorder = isUpsell ? "hover:border-white/40" : "hover:border-sb-gold/60";
          
          // Mobile: Horizontal flex (image left, text right). Desktop: Vertical flex (image top, text bottom).
          // Both are constrained tightly to their parent's flex-1 height, preventing any scrolling.
          return `
            <div class="flex flex-row md:flex-col flex-1 bg-white/5 border border-white/10 ${highlightBorder} transition-all duration-700 rounded-sm overflow-hidden group min-h-0 relative backdrop-blur-sm shadow-2xl">
                
                <!-- Image Container (Takes 40% width on mobile, 55% height on desktop) -->
                <div class="w-[40%] md:w-full md:h-[55%] relative overflow-hidden bg-black shrink-0">
                    <div class="absolute top-2 md:top-4 left-2 md:left-4 ${badgeClass} text-[8px] md:text-[9px] uppercase tracking-luxury font-bold px-3 py-1 z-10 border backdrop-blur-md">
                        ${label}
                    </div>
                    <img 
                        src="${product.image}" 
                        alt="${product.title}" 
                        class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.05] opacity-80 group-hover:opacity-100 transition-all duration-1000 ease-out" 
                        onerror="this.onerror=null; this.src='/images/collection-signature.jpg';"
                    />
                </div>
                
                <!-- Text Container (Takes remaining space) -->
                <div class="flex-1 flex flex-col justify-center items-center text-center p-4 md:p-6 relative z-10">
                    <h4 class="font-serif text-xl md:text-3xl text-white mb-1 md:mb-2 line-clamp-2">${product.title}</h4>
                    <p class="text-sb-gold text-sm md:text-lg font-light mb-4 md:mb-6">£${product.price.toFixed(2)}</p>
                    <a href="/products/${product.handle}" class="border border-white/20 text-white py-2.5 px-6 text-[9px] md:text-[10px] font-bold uppercase tracking-luxury hover:bg-sb-gold hover:text-sb-black transition-all duration-500 w-full md:w-auto shrink-0">
                        View Bouquet
                    </a>
                </div>
            </div>
          `;
      }

    });
  </script>
</Layout>
