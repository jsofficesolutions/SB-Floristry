---
import Layout from '../layouts/Layout.astro';
import { shopifyFetch } from '../utils/shopify.js';
import { Image } from 'astro:assets';

// Fetch live products to power the instant client-side matching quiz
const query = `{
  products(first: 50) {
    edges {
      node {
        id
        title
        handle
        description
        tags
        images(first: 1) { 
          edges { 
            node { 
              url 
            } 
          } 
        }
        priceRange { 
          minVariantPrice { 
            amount 
          } 
        }
      }
    }
  }
}`;

const response = await shopifyFetch({ query });
const products = response?.data?.products?.edges.map(e => e.node) || [];
---

<Layout 
  title="Bloom Matcher - Interactive Floral Finder" 
  description="Take our quick interactive quiz to find the perfect luxury hand-tied arrangement customized for your occasion, aesthetic, and budget."
>
  <section class="py-32 bg-sb-cream min-h-screen flex items-center">
    <div class="container mx-auto px-6 max-w-3xl">
      <div class="text-center mb-12">
        <span class="text-sb-gold text-xs tracking-luxury uppercase font-bold mb-4 block">Interactive Curation</span>
        <h1 class="font-serif text-5xl md:text-6xl text-sb-black mb-6">The Bloom Matcher</h1>
        <p class="text-gray-500 font-light max-w-lg mx-auto text-sm leading-relaxed">
          Discover your perfect floral match. Select your occasion, preferred aesthetic, and budget below for an instant custom curation.
        </p>
      </div>

      <!-- Quiz Card Container -->
      <div class="bg-white p-8 md:p-12 shadow-2xl relative border border-gray-100 rounded-sm overflow-hidden">
        <!-- Top Thin Gold Progress Bar -->
        <div class="absolute top-0 left-0 w-full h-1 bg-gray-100">
          <div id="quiz-progress-bar" class="h-full bg-sb-gold transition-all duration-500 w-[33%]"></div>
        </div>

        <!-- Step Indicator Text -->
        <div class="flex justify-between items-center mb-10 border-b border-gray-100 pb-4 text-[10px] tracking-luxury uppercase font-bold text-gray-400">
          <span id="step-label">Step 1 of 3</span>
          <span class="text-sb-gold">SB Studio</span>
        </div>

        <div id="quiz-flow">
          <!-- STEP 1: Occasion -->
          <div id="step-1" class="space-y-6">
            <h3 class="font-serif text-2xl text-sb-black font-light mb-2">What is the special occasion?</h3>
            <p class="text-xs text-gray-400 uppercase tracking-widest mb-6">Select one to begin</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <button class="quiz-btn border border-gray-200 p-6 text-left hover:border-sb-gold hover:bg-sb-cream/30 transition-all duration-300 flex items-center justify-between group" data-step="1" data-val="anniversary">
                <div>
                  <h4 class="font-serif text-lg text-sb-black font-normal">Anniversary & Romance</h4>
                  <p class="text-xs text-gray-400 font-light mt-1">Deep sentiments, classic love, and poetry</p>
                </div>
                <i class="fas fa-heart text-gray-300 group-hover:text-sb-gold transition-colors ml-4 text-xl"></i>
              </button>

              <button class="quiz-btn border border-gray-200 p-6 text-left hover:border-sb-gold hover:bg-sb-cream/30 transition-all duration-300 flex items-center justify-between group" data-step="1" data-val="birthday">
                <div>
                  <h4 class="font-serif text-lg text-sb-black font-normal">Birthday & Cheer</h4>
                  <p class="text-xs text-gray-400 font-light mt-1">Celebrations, vibrant palettes, and joy</p>
                </div>
                <i class="fas fa-cake-candles text-gray-300 group-hover:text-sb-gold transition-colors ml-4 text-xl"></i>
              </button>

              <button class="quiz-btn border border-gray-200 p-6 text-left hover:border-sb-gold hover:bg-sb-cream/30 transition-all duration-300 flex items-center justify-between group" data-step="1" data-val="sympathy">
                <div>
                  <h4 class="font-serif text-lg text-sb-black font-normal">Sympathy & Solace</h4>
                  <p class="text-xs text-gray-400 font-light mt-1">Quiet thoughts, elegant support, and respect</p>
                </div>
                <i class="fas fa-dove text-gray-300 group-hover:text-sb-gold transition-colors ml-4 text-xl"></i>
              </button>

              <button class="quiz-btn border border-gray-200 p-6 text-left hover:border-sb-gold hover:bg-sb-cream/30 transition-all duration-300 flex items-center justify-between group" data-step="1" data-val="just-because">
                <div>
                  <h4 class="font-serif text-lg text-sb-black font-normal">Just Because</h4>
                  <p class="text-xs text-gray-400 font-light mt-1">Spontaneous gestures, warmth, and surprise</p>
                </div>
                <i class="fas fa-sparkles text-gray-300 group-hover:text-sb-gold transition-colors ml-4 text-xl"></i>
              </button>
            </div>
          </div>

          <!-- STEP 2: Aesthetic / Vibe (Matches Shopify tags) -->
          <div id="step-2" class="hidden space-y-6">
            <h3 class="font-serif text-2xl text-sb-black font-light mb-2">Choose their floral aesthetic</h3>
            <p class="text-xs text-gray-400 uppercase tracking-widest mb-6">Each arrangement is tailored to a distinct design theme</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <button class="quiz-btn border border-gray-200 p-6 text-left hover:border-sb-gold hover:bg-sb-cream/30 transition-all duration-300 flex items-center justify-between group" data-step="2" data-val="luxury">
                <div>
                  <h4 class="font-serif text-lg text-sb-black font-normal">Timeless & Luxury</h4>
                  <p class="text-xs text-gray-400 font-light mt-1">Classic premium whites, sophisticated greenery</p>
                </div>
                <span class="text-xs text-sb-gold font-serif italic font-bold">Luxury</span>
              </button>

              <button class="quiz-btn border border-gray-200 p-6 text-left hover:border-sb-gold hover:bg-sb-cream/30 transition-all duration-300 flex items-center justify-between group" data-step="2" data-val="gothic">
                <div>
                  <h4 class="font-serif text-lg text-sb-black font-normal">Gothic & Dramatic</h4>
                  <p class="text-xs text-gray-400 font-light mt-1">Deep velvety plum tones, dark mystery, bold contours</p>
                </div>
                <span class="text-xs text-sb-gold font-serif italic font-bold">Gothic</span>
              </button>

              <button class="quiz-btn border border-gray-200 p-6 text-left hover:border-sb-gold hover:bg-sb-cream/30 transition-all duration-300 flex items-center justify-between group" data-step="2" data-val="fairytale">
                <div>
                  <h4 class="font-serif text-lg text-sb-black font-normal">Soft & Fairytale</h4>
                  <p class="text-xs text-gray-400 font-light mt-1">Romantic pastels, dreamy meadow-style garden blooms</p>
                </div>
                <span class="text-xs text-sb-gold font-serif italic font-bold">Fairytale</span>
              </button>

              <button class="quiz-btn border border-gray-200 p-6 text-left hover:border-sb-gold hover:bg-sb-cream/30 transition-all duration-300 flex items-center justify-between group" data-step="2" data-val="seasonal">
                <div>
                  <h4 class="font-serif text-lg text-sb-black font-normal">Bright & Seasonal</h4>
                  <p class="text-xs text-gray-400 font-light mt-1">Evolving garden color palettes handpicked today</p>
                </div>
                <span class="text-xs text-sb-gold font-serif italic font-bold">Seasonal</span>
              </button>
            </div>
            
            <button id="back-to-1" class="text-[10px] tracking-luxury uppercase font-bold text-gray-400 hover:text-sb-black pt-4 block"><i class="fas fa-chevron-left mr-2"></i> Back to Occasion</button>
          </div>

          <!-- STEP 3: Budget Range -->
          <div id="step-3" class="hidden space-y-6">
            <h3 class="font-serif text-2xl text-sb-black font-light mb-2">Select your ideal arrangement scale</h3>
            <p class="text-xs text-gray-400 uppercase tracking-widest mb-6">Filter by budget range</p>
            <div class="grid grid-cols-1 gap-4">
              <button class="quiz-btn border border-gray-200 p-6 text-left hover:border-sb-gold hover:bg-sb-cream/30 transition-all duration-300 flex items-center justify-between group" data-step="3" data-val="under-50">
                <div>
                  <h4 class="font-serif text-lg text-sb-black font-normal">Bespoke Bouquets <span class="text-base text-gray-400 font-sans ml-2">(Under £50)</span></h4>
                  <p class="text-xs text-gray-400 font-light mt-1">Charming table displays and elegant hand-tied arrangements</p>
                </div>
                <i class="fas fa-chevron-right text-gray-300 group-hover:text-sb-gold transition-all"></i>
              </button>

              <button class="quiz-btn border border-gray-200 p-6 text-left hover:border-sb-gold hover:bg-sb-cream/30 transition-all duration-300 flex items-center justify-between group" data-step="3" data-val="50-100">
                <div>
                  <h4 class="font-serif text-lg text-sb-black font-normal">Premium Masterpieces <span class="text-base text-gray-400 font-sans ml-2">(£50 - £100)</span></h4>
                  <p class="text-xs text-gray-400 font-light mt-1">Generous, showstopping focal displays full of luxury textures</p>
                </div>
                <i class="fas fa-chevron-right text-gray-300 group-hover:text-sb-gold transition-all"></i>
              </button>

              <button class="quiz-btn border border-gray-200 p-6 text-left hover:border-sb-gold hover:bg-sb-cream/30 transition-all duration-300 flex items-center justify-between group" data-step="3" data-val="all">
                <div>
                  <h4 class="font-serif text-lg text-sb-black font-normal">Show All Collections <span class="text-base text-gray-400 font-sans ml-2">(Any Budget)</span></h4>
                  <p class="text-xs text-gray-400 font-light mt-1">Browse all arrangements matching your chosen style profile</p>
                </div>
                <i class="fas fa-chevron-right text-gray-300 group-hover:text-sb-gold transition-all"></i>
              </button>
            </div>

            <button id="back-to-2" class="text-[10px] tracking-luxury uppercase font-bold text-gray-400 hover:text-sb-black pt-4 block"><i class="fas fa-chevron-left mr-2"></i> Back to Aesthetic</button>
          </div>
        </div>

        <!-- RESULTS CONTAINER (Hidden initially) -->
        <div id="quiz-results" class="hidden space-y-8 animate-fade-in">
          <div class="flex items-center justify-between border-b border-gray-100 pb-6">
            <div>
              <h3 class="font-serif text-2xl text-sb-black font-light">Your Custom Curations</h3>
              <p class="text-[10px] text-gray-400 uppercase tracking-widest mt-1">Hand-selected based on your style and budget preference</p>
            </div>
            <button id="restart-quiz" class="text-[10px] tracking-luxury uppercase font-bold text-sb-gold border-b border-sb-gold pb-0.5 hover:text-sb-black hover:border-sb-black transition-colors">Start Over</button>
          </div>

          <!-- Live Matching Grid -->
          <div id="results-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <!-- Dynamic Cards Injected Here -->
          </div>

          <!-- Empty Fallback Message -->
          <div id="no-matches" class="hidden text-center py-12 space-y-4">
            <i class="fas fa-leaf text-gray-300 text-4xl"></i>
            <h4 class="font-serif text-xl">Almost a Perfect Match</h4>
            <p class="text-xs text-gray-500 max-w-md mx-auto leading-relaxed">
              We don't have items perfectly matching that specific budget combination today, but our custom design service can tailor any bouquet to your specific cost requirements.
            </p>
            <a href="/contact" class="inline-block border border-sb-black text-sb-black hover:bg-sb-black hover:text-sb-cream px-6 py-3 text-[10px] font-bold tracking-luxury uppercase transition-all duration-300">
              Get A Bespoke Quote
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script is:inline define:vars={{ products }}>
  // Core State
  let selection = {
    occasion: '',
    aesthetic: '',
    budget: ''
  };

  document.addEventListener('astro:page-load', () => {
    const step1 = document.getElementById('step-1');
    const step2 = document.getElementById('step-2');
    const step3 = document.getElementById('step-3');
    const resultsContainer = document.getElementById('quiz-results');
    const resultsGrid = document.getElementById('results-grid');
    const noMatches = document.getElementById('no-matches');
    const progressBar = document.getElementById('quiz-progress-bar');
    const stepLabel = document.getElementById('step-label');

    // Handle Button Clicks
    document.querySelectorAll('.quiz-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const step = btn.dataset.step;
        const val = btn.dataset.val;

        if (step === '1') {
          selection.occasion = val;
          goToStep(2);
        } else if (step === '2') {
          selection.aesthetic = val;
          goToStep(3);
        } else if (step === '3') {
          selection.budget = val;
          showResults();
        }
      });
    });

    // Navigation Back buttons
    document.getElementById('back-to-1')?.addEventListener('click', () => goToStep(1));
    document.getElementById('back-to-2')?.addEventListener('click', () => goToStep(2));
    document.getElementById('restart-quiz')?.addEventListener('click', () => {
      selection = { occasion: '', aesthetic: '', budget: '' };
      goToStep(1);
    });

    function goToStep(stepNum) {
      step1.classList.add('hidden');
      step2.classList.add('hidden');
      step3.classList.add('hidden');
      resultsContainer.classList.add('hidden');

      if (stepNum === 1) {
        step1.classList.remove('hidden');
        progressBar.style.width = '33%';
        stepLabel.innerText = 'Step 1 of 3';
      } else if (stepNum === 2) {
        step2.classList.remove('hidden');
        progressBar.style.width = '66%';
        stepLabel.innerText = 'Step 2 of 3';
      } else if (stepNum === 3) {
        step3.classList.remove('hidden');
        progressBar.style.width = '100%';
        stepLabel.innerText = 'Step 3 of 3';
      }
    }

    function showResults() {
      step3.classList.add('hidden');
      resultsContainer.classList.remove('hidden');
      progressBar.style.width = '100%';
      stepLabel.innerText = 'Selection Complete';

      // Filtering Logic
      const matches = products.filter(product => {
        // Tag Match
        const normalizedTags = (product.tags || []).map(t => t.toLowerCase());
        const hasAestheticTag = normalizedTags.includes(selection.aesthetic.toLowerCase());
        
        // Budget Match
        const price = parseFloat(product.priceRange.minVariantPrice.amount);
        let matchesBudget = false;
        
        if (selection.budget === 'under-50') {
          matchesBudget = price < 50;
        } else if (selection.budget === '50-100') {
          matchesBudget = price >= 50 && price <= 100;
        } else {
          matchesBudget = true; // Show all
        }

        return hasAestheticTag && matchesBudget;
      });

      // Render Match Grid
      if (matches.length > 0) {
        noMatches.classList.add('hidden');
        resultsGrid.classList.remove('hidden');
        
        resultsGrid.innerHTML = matches.map(match => {
          const imgUrl = match.images?.edges?.[0]?.node?.url || 'https://via.placeholder.com/600x800?text=Coming+Soon';
          const price = parseFloat(match.priceRange.minVariantPrice.amount).toFixed(2);
          
          return `
            <div class="group border border-gray-100 p-4 hover:shadow-xl transition-all duration-500 bg-[#F9F8F6]/40 reveal active">
              <a href="/products/${match.handle}" class="block space-y-4">
                <div class="h-80 overflow-hidden relative">
                  <img 
                    src="${imgUrl}" 
                    alt="${match.title}" 
                    class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 loaded" 
                    style="opacity: 1 !important;"
                  />
                  <div class="absolute top-3 left-3 bg-sb-black text-sb-gold text-[8px] uppercase tracking-widest font-bold py-1.5 px-3">
                    ${selection.aesthetic} Vibe
                  </div>
                </div>
                <div class="space-y-1 text-center">
                  <h4 class="font-serif text-xl text-sb-black font-light group-hover:text-sb-gold transition-colors duration-300">${match.title}</h4>
                  <p class="text-sb-gold text-xs font-bold font-sans">£${price}</p>
                  <span class="text-[9px] uppercase tracking-luxury border-b border-transparent group-hover:border-sb-black pb-0.5 inline-block transition-all duration-300 mt-2">
                    View Bouquet Details
                  </span>
                </div>
              </a>
            </div>
          `;
        }).join('');
      } else {
        resultsGrid.classList.add('hidden');
        noMatches.classList.remove('hidden');
      }
    }
  });
</script>
