---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Occasion Finder | SB Floristry" description="Find the perfect luxury bouquet for any occasion with our interactive flower finder.">
  <section class="min-h-screen bg-sb-cream flex items-center justify-center py-24 px-6">
    
    <div class="max-w-2xl w-full bg-white border border-gray-200 shadow-2xl p-8 md:p-16 text-center relative overflow-hidden" id="quiz-container">
      
      <!-- Progress Bar -->
      <div class="absolute top-0 left-0 w-full h-1 bg-gray-100">
        <div class="h-full bg-sb-gold transition-all duration-500 w-1/3" id="progress-bar"></div>
      </div>

      <!-- Step 1: Who is it for? -->
      <div class="quiz-step active" id="step-1">
        <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-4 block">Step 1 of 3</span>
        <h2 class="font-serif text-3xl md:text-4xl text-sb-black mb-8 font-light">Who are we spoiling today?</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <button class="quiz-btn border border-gray-200 py-4 px-6 hover:border-sb-gold hover:bg-gray-50 transition-colors text-sb-black font-light" data-next="step-2">My Partner</button>
          <button class="quiz-btn border border-gray-200 py-4 px-6 hover:border-sb-gold hover:bg-gray-50 transition-colors text-sb-black font-light" data-next="step-2">A Friend or Family Member</button>
          <button class="quiz-btn border border-gray-200 py-4 px-6 hover:border-sb-gold hover:bg-gray-50 transition-colors text-sb-black font-light" data-next="step-2">A Colleague / Client</button>
          <button class="quiz-btn border border-gray-200 py-4 px-6 hover:border-sb-gold hover:bg-gray-50 transition-colors text-sb-black font-light" data-next="step-2">Just for Me (Treat yourself!)</button>
        </div>
      </div>

      <!-- Step 2: What's the vibe? -->
      <div class="quiz-step hidden" id="step-2">
        <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-4 block">Step 2 of 3</span>
        <h2 class="font-serif text-3xl md:text-4xl text-sb-black mb-8 font-light">What's the overall vibe?</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <button class="quiz-btn border border-gray-200 py-4 px-6 hover:border-sb-gold hover:bg-gray-50 transition-colors text-sb-black font-light" data-next="step-3" data-tag="signature">Romantic & Deep</button>
          <button class="quiz-btn border border-gray-200 py-4 px-6 hover:border-sb-gold hover:bg-gray-50 transition-colors text-sb-black font-light" data-next="step-3" data-tag="seasonal">Bright & Cheerful</button>
          <button class="quiz-btn border border-gray-200 py-4 px-6 hover:border-sb-gold hover:bg-gray-50 transition-colors text-sb-black font-light" data-next="step-3" data-tag="signature">Classic & Elegant</button>
          <button class="quiz-btn border border-gray-200 py-4 px-6 hover:border-sb-gold hover:bg-gray-50 transition-colors text-sb-black font-light" data-next="step-3" data-tag="sympathy">Soft & Sympathetic</button>
        </div>
      </div>

      <!-- Step 3: Budget -->
      <div class="quiz-step hidden" id="step-3">
        <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-4 block">Step 3 of 3</span>
        <h2 class="font-serif text-3xl md:text-4xl text-sb-black mb-8 font-light">What's your preferred price range?</h2>
        <div class="flex flex-col gap-4 max-w-sm mx-auto">
          <button class="quiz-btn border border-gray-200 py-4 px-6 hover:border-sb-gold hover:bg-gray-50 transition-colors text-sb-black font-light finish-quiz" data-price="40-60">£40 - £60</button>
          <button class="quiz-btn border border-gray-200 py-4 px-6 hover:border-sb-gold hover:bg-gray-50 transition-colors text-sb-black font-light finish-quiz" data-price="60-100">£60 - £100</button>
          <button class="quiz-btn border border-gray-200 py-4 px-6 hover:border-sb-gold hover:bg-gray-50 transition-colors text-sb-black font-light finish-quiz" data-price="100+">£100+ (Showstopper)</button>
        </div>
      </div>

      <!-- Loading / Result State -->
      <div class="quiz-step hidden" id="step-result">
        <i class="fas fa-circle-notch fa-spin text-4xl text-sb-gold mb-6"></i>
        <h2 class="font-serif text-2xl text-sb-black mb-4 font-light">Curating your perfect match...</h2>
      </div>

    </div>
  </section>

  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      const buttons = document.querySelectorAll('.quiz-btn');
      const progressBar = document.getElementById('progress-bar');
      let selectedTag = 'seasonal'; // default fallback

      buttons.forEach(btn => {
        btn.addEventListener('click', (e) => {
          
          // Capture the tag if this button has one (from Step 2)
          if(e.target.dataset.tag) {
            selectedTag = e.target.dataset.tag;
          }

          // If it's the final button
          if (e.target.classList.contains('finish-quiz')) {
            document.getElementById('step-3').classList.add('hidden');
            document.getElementById('step-result').classList.remove('hidden');
            progressBar.style.width = '100%';
            
            // Simulate a short "calculating" pause for premium feel, then redirect to the best collection
            setTimeout(() => {
              window.location.href = `/collections/${selectedTag}`;
            }, 1200);
            return;
          }

          // Handle normal next steps
          const nextStepId = e.target.dataset.next;
          if (nextStepId) {
            // Hide all steps
            document.querySelectorAll('.quiz-step').forEach(step => step.classList.add('hidden'));
            // Show next step
            document.getElementById(nextStepId).classList.remove('hidden');
            
            // Update progress bar
            if (nextStepId === 'step-2') progressBar.style.width = '66%';
            if (nextStepId === 'step-3') progressBar.style.width = '90%';
          }
        });
      });
    });
  </script>
</Layout>
