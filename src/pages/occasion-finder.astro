---
import Layout from '../layouts/Layout.astro';
import { shopifyFetch } from '../utils/shopify.js';

// Fetch all products INCLUDING their descriptions at build time
const query = `
  {
    products(first: 100) {
      edges {
        node {
          title
          handle
          tags
          description
          priceRange {
            minVariantPrice {
              amount
            }
          }
          images(first: 1) {
            edges {
              node {
                url
              }
            }
          }
        }
      }
    }
  }
`;

const response = await shopifyFetch({ query });
const rawProducts = response?.data?.products?.edges || [];

// Clean up the data to make it easy for our client-side script to search
const products = rawProducts.map(({ node }) => ({
  title: node.title,
  handle: node.handle,
  tags: node.tags.map(t => t.toLowerCase().trim()),
  description: (node.description || '').toLowerCase(),
  price: parseFloat(node.priceRange.minVariantPrice.amount),
  image: node.images.edges[0]?.node?.url || '/images/collection-signature.jpg'
}));
---

<Layout title="AI Gift Advisor | SB Floristry" description="Let our intelligent AI Gift Advisor find the perfect luxury bouquet for your occasion.">
  
  <!-- Step 1-3 Quiz Background -->
  <!-- FIX: Switched to min-h-[100dvh] with pt-24 pb-12 to perfectly center on mobile below the header -->
  <section class="min-h-[100dvh] bg-sb-cream flex flex-col items-center justify-center px-4 md:px-6 relative pt-24 pb-12" id="quiz-background">
    
    <!-- FIXED HEIGHT CONTAINER: Locks proportions so the box never jumps -->
    <div class="max-w-4xl w-full bg-white border border-gray-100 shadow-xl p-4 md:p-12 text-center relative overflow-hidden transition-all duration-1000 h-[380px] sm:h-[420px] md:h-[500px] flex flex-col justify-center items-center" id="quiz-container">
      
      <!-- Progress Bar -->
      <div class="absolute top-0 left-0 w-full h-1 bg-gray-50" id="progress-container">
        <div class="h-full bg-sb-gold transition-all duration-1000 ease-in-out w-0" id="progress-bar"></div>
      </div>

      <!-- Step 1: Who is it for? -->
      <div class="quiz-step w-full opacity-100 translate-y-0 transition-all duration-700 ease-out absolute px-4 md:px-16" id="step-1">
        <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-3 md:mb-6 block"><i class="fas fa-sparkles mr-1"></i> AI Gift Advisor</span>
        <h2 class="font-serif text-2xl sm:text-3xl md:text-5xl text-sb-black mb-5 md:mb-10 font-light">Who are we spoiling today?</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-5 max-w-2xl mx-auto">
          <button class="quiz-btn border border-gray-100 py-3 md:py-4 px-4 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-sm md:text-lg" data-next="step-2" data-keywords="romantic,love,red,rose,passion,heart,kiss,anniversary">My Partner</button>
          <button class="quiz-btn border border-gray-100 py-3 md:py-4 px-4 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-sm md:text-lg" data-next="step-2" data-keywords="cheerful,bright,yellow,garden,delight,wildflower,warm,sunflower,friend">A Friend or Family</button>
          <button class="quiz-btn border border-gray-100 py-3 md:py-4 px-4 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-sm md:text-lg" data-next="step-2" data-keywords="corporate,elegant,sophisticated,white,classic,office,desk,formal">A Colleague / Client</button>
          <button class="quiz-btn border border-gray-100 py-3 md:py-4 px-4 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-sm md:text-lg" data-next="step-2" data-keywords="luxury,indulgent,fragrant,opulent,premium,treat,beautiful">Treating Myself</button>
        </div>
      </div>

      <!-- Step 2: What's the vibe? -->
      <div class="quiz-step w-full hidden opacity-0 translate-y-4 transition-all duration-700 ease-out absolute px-4 md:px-16" id="step-2">
        <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-3 md:mb-6 block">Step 2 of 3</span>
        <h2 class="font-serif text-2xl sm:text-3xl md:text-5xl text-sb-black mb-5 md:mb-10 font-light">What's the overall vibe?</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-5 max-w-2xl mx-auto">
          <button class="quiz-btn border border-gray-100 py-3 md:py-4 px-4 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-sm md:text-lg" data-next="step-3" data-keywords="red,velvet,deep,moody,gothic,dark,wine,crimson,burgundy">Romantic & Deep</button>
          <button class="quiz-btn border border-gray-100 py-3 md:py-4 px-4 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-sm md:text-lg" data-next="step-3" data-keywords="spring,summer,bright,wild,meadow,colorful,orange,vibrant,pink">Bright & Fresh</button>
          <button class="quiz-btn border border-gray-100 py-3 md:py-4 px-4 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-sm md:text-lg" data-next="step-3" data-keywords="white,cream,orchid,elegant,pure,hydrangea,classic,timeless">Classic & Elegant</button>
          <button class="quiz-btn border border-gray-100 py-3 md:py-4 px-4 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-sm md:text-lg" data-next="step-3" data-keywords="pastel,soft,sympathy,gentle,blush,peach,delicate,lily,peace">Soft & Gentle</button>
        </div>
      </div>

      <!-- Step 3: Budget -->
      <div class="quiz-step w-full hidden opacity-0 translate-y-4 transition-all duration-700 ease-out absolute px-4 md:px-16" id="step-3">
        <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-3 md:mb-6 block">Step 3 of 3</span>
        <h2 class="font-serif text-2xl sm:text-3xl md:text-5xl text-sb-black mb-5 md:mb-10 font-light">What is your price range?</h2>
        <div class="flex flex-col gap-3 md:gap-5 max-w-md mx-auto w-full">
          <button class="quiz-btn border border-gray-100 py-3 md:py-4 px-4 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-sm md:text-lg finish-quiz" data-min="40" data-max="60">£40 - £60</button>
          <button class="quiz-btn border border-gray-100 py-3 md:py-4 px-4 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-sm md:text-lg finish-quiz" data-min="61" data-max="99">£60 - £100</button>
          <button class="quiz-btn border border-gray-100 py-3 md:py-4 px-4 hover:border-sb-gold hover:bg-gray-50 hover:shadow-sm transition-all duration-500 text-sb-black font-light text-sm md:text-lg finish-quiz" data-min="100" data-max="999">£100+ (Showstopper)</button>
        </div>
      </div>
    </div>
  </section>

  <!-- THE CINEMATIC FULLSCREEN OVERLAY (AI Loading + Results) -->
  <div id="cinematic-overlay" class="fixed inset-0 bg-sb-black z-[100] opacity-0 pointer-events-none transition-opacity duration-1000 flex flex-col items-center justify-center overflow-hidden">
    
    <!-- Ambient Background Lighting & Sparkles -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-sb-gold rounded-full opacity-[0.04] blur-[100px]"></div>
        <div class="absolute top-[20%] left-[15%] w-1.5 h-1.5 bg-sb-gold rounded-full animate-pulse opacity-40 blur-[1px]"></div>
        <div class="absolute top-[70%] left-[80%] w-2 h-2 bg-white rounded-full animate-[pulse_4s_ease-in-out_infinite] opacity-30 blur-[2px]"></div>
        <div class="absolute top-[40%] left-[85%] w-1 h-1 bg-sb-gold rounded-full animate-[pulse_3s_ease-in-out_infinite] opacity-50"></div>
        <div class="absolute top-[80%] left-[20%] w-2.5 h-2.5 bg-sb-gold rounded-full animate-pulse opacity-20 blur-[3px]"></div>
    </div>

    <!-- AI Loading View -->
    <div id="ai-loading-view" class="relative z-10 flex flex-col items-center transition-all duration-1000 ease-in-out opacity-100 scale-100 w-full px-6 text-center">
        <div class="relative w-32 h-32 md:w-40 md:h-40 mx-auto mb-10 md:mb-12 flex items-center justify-center">
            <div class="absolute inset-0 bg-sb-gold rounded-full blur-2xl opacity-20 animate-pulse"></div>
            <div class="absolute inset-0 border-[1px] border-sb-gold/30 rounded-full animate-[spin_6s_linear_infinite]"></div>
            <div class="absolute inset-0 border-[1px] border-sb-gold/15 rounded-full animate-[spin_8s_linear_infinite_reverse] scale-110"></div>
            <i class="fas fa-magic text-3xl md:text-4xl text-sb-gold relative z-10 animate-pulse"></i>
        </div>
        <h2 class="font-serif text-2xl md:text-4xl text-white mb-3 md:mb-4 font-light transition-all duration-1000 ease-in-out transform translate-y-0" id="ai-loading-text">Initializing AI Advisor...</h2>
        <p class="text-sb-gold/70 text-xs md:text-sm font-light uppercase tracking-widest" id="ai-loading-subtext">Please wait</p>
    </div>

    <!-- Final Results View (Scrollable on mobile to fit 3 cards gracefully) -->
    <div id="ai-results-view" class="absolute inset-0 z-20 hidden flex-col items-center justify-start md:justify-center p-4 md:p-8 opacity-0 scale-105 transition-all duration-1000 w-full h-full overflow-y-auto overflow-x-hidden pt-12 md:pt-8 pb-20">
        
        <!-- Header -->
        <div class="text-center shrink-0 mb-6 md:mb-10 w-full">
            <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-3 block"><i class="fas fa-check text-sb-gold mr-2"></i>Curated Selection</span>
            <h2 class="font-serif text-3xl md:text-5xl text-white font-light">Your Perfect Matches</h2>
        </div>
        
        <!-- 3-Card Grid (Center focused) -->
        <div class="w-full max-w-[1400px] mx-auto flex flex-col md:flex-row justify-center items-center gap-4 md:gap-6 shrink-0" id="results-grid">
            <!-- Products injected here via JS -->
        </div>

        <!-- Footer -->
        <div class="shrink-0 mt-8 md:mt-12 pt-6 border-t border-white/10 w-full max-w-xl text-center mx-auto">
            <button id="restart-concierge-btn" class="text-gray-400 hover:text-sb-gold text-[10px] tracking-luxury uppercase font-bold transition-colors duration-300">
                <i class="fas fa-redo mr-2"></i> Restart Advisor
            </button>
        </div>
    </div>

  </div>

  <!-- THE LIGHTBOX GALLERY OVERLAY -->
  <div id="lightbox-overlay" class="fixed inset-0 z-[200] bg-sb-black/95 hidden opacity-0 transition-opacity duration-300 flex flex-col items-center justify-center backdrop-blur-md" onclick="window.closeLightbox()">
      
      <!-- Close Button -->
      <button class="absolute top-6 right-6 text-white/60 hover:text-sb-gold text-3xl md:text-4xl z-50 transition-colors p-2" onclick="window.closeLightbox()">
          <i class="fas fa-times"></i>
      </button>

      <!-- Navigation Arrows -->
      <button class="absolute left-2 md:left-10 top-1/2 -translate-y-1/2 text-white/30 hover:text-sb-gold text-4xl md:text-5xl z-50 transition-colors p-4" onclick="window.lightboxPrev(event)">
          <i class="fas fa-chevron-left"></i>
      </button>
      <button class="absolute right-2 md:right-10 top-1/2 -translate-y-1/2 text-white/30 hover:text-sb-gold text-4xl md:text-5xl z-50 transition-colors p-4" onclick="window.lightboxNext(event)">
          <i class="fas fa-chevron-right"></i>
      </button>

      <!-- Lightbox Content -->
      <div class="relative w-full max-w-5xl h-[70vh] md:h-[80vh] flex flex-col items-center justify-center px-12 md:px-24" onclick="event.stopPropagation()">
          <img id="lightbox-img" src="" class="w-full h-full object-contain drop-shadow-2xl mb-8" alt="Bouquet Full View" />
          
          <div class="text-center absolute bottom-0 translate-y-[120%] w-full">
              <span id="lightbox-badge" class="text-sb-black bg-sb-gold text-[10px] uppercase tracking-luxury font-bold px-3 py-1 mb-3 inline-block shadow-sm">Match</span>
              <h3 id="lightbox-title" class="font-serif text-2xl md:text-4xl text-white mb-2 font-light tracking-wide"></h3>
              <p id="lightbox-price" class="text-sb-gold text-lg md:text-xl font-light"></p>
          </div>
      </div>
  </div>

  <!-- Pass Shopify products securely to the client -->
  <script id="product-data" type="application/json" set:html={JSON.stringify(products)}></script>

  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      
      const buttons = document.querySelectorAll('.quiz-btn');
      const progressBar = document.getElementById('progress-bar');
      const restartBtn = document.getElementById('restart-concierge-btn');
      
      let userPreferences = { keywords: [], min: 0, max: 999 };

      const loadingPhrases = [
          { main: "Analyzing floral profiles...", sub: "Scanning Essex inventory" },
          { main: "Evaluating seasonal availability...", sub: "Matching colour palettes" },
          { main: "Curating your perfect match...", sub: "Calculating sentiment" },
          { main: "Finalizing recommendations...", sub: "Almost ready" }
      ];

      const productsDataEl = document.getElementById('product-data');
      if(!productsDataEl) return;
      const allProducts = JSON.parse(productsDataEl.innerHTML);

      setTimeout(() => { if(progressBar) progressBar.style.width = '33%'; }, 300);

      // --- SMOOTH RESTART LOGIC ---
      if (restartBtn) {
          restartBtn.addEventListener('click', () => {
              window.scrollTo({ top: 0, behavior: 'smooth' });

              userPreferences = { keywords: [], min: 0, max: 999 };
              
              const overlay = document.getElementById('cinematic-overlay');
              overlay.classList.remove('opacity-100', 'pointer-events-auto');
              overlay.classList.add('opacity-0', 'pointer-events-none');
              
              setTimeout(() => {
                  document.getElementById('ai-results-view').classList.add('hidden');
                  document.getElementById('ai-loading-view').classList.remove('hidden', 'opacity-0', 'scale-95');
                  document.getElementById('ai-loading-view').classList.add('opacity-100', 'scale-100');
                  
                  document.querySelectorAll('.quiz-step').forEach(step => {
                      step.classList.add('hidden', 'opacity-0', 'translate-y-4');
                      step.classList.remove('opacity-100', 'translate-y-0');
                  });
                  const step1 = document.getElementById('step-1');
                  step1.classList.remove('hidden', 'translate-y-4');
                  step1.classList.add('opacity-100', 'translate-y-0');
                  
                  progressBar.style.width = '33%';
              }, 1000);
          });
      }

      function transitionToNextStep(hideId, showId, newProgress) {
          const hideEl = document.getElementById(hideId);
          const showEl = document.getElementById(showId);
          
          hideEl.classList.remove('opacity-100', 'translate-y-0');
          hideEl.classList.add('opacity-0', '-translate-y-4'); 
          
          if(progressBar && newProgress) progressBar.style.width = newProgress;

          setTimeout(() => {
              hideEl.classList.add('hidden');
              hideEl.classList.remove('-translate-y-4');
              hideEl.classList.add('translate-y-4');
              
              showEl.classList.remove('hidden');
              void showEl.offsetWidth; 
              
              showEl.classList.remove('opacity-0', 'translate-y-4');
              showEl.classList.add('opacity-100', 'translate-y-0');
          }, 600);
      }

      buttons.forEach(btn => {
        btn.addEventListener('click', (e) => {
          const clicked = e.currentTarget;
          const currentStepId = clicked.closest('.quiz-step').id;
          
          if(clicked.dataset.keywords) {
              const kws = clicked.dataset.keywords.split(',');
              userPreferences.keywords.push(...kws);
          }
          if(clicked.dataset.min) {
              userPreferences.min = parseInt(clicked.dataset.min);
              userPreferences.max = parseInt(clicked.dataset.max);
          }

          if (clicked.classList.contains('finish-quiz')) {
            const overlay = document.getElementById('cinematic-overlay');
            const loadingText = document.getElementById('ai-loading-text');
            const loadingSub = document.getElementById('ai-loading-subtext');
            
            overlay.classList.remove('opacity-0', 'pointer-events-none');
            overlay.classList.add('opacity-100', 'pointer-events-auto');

            let phraseIndex = 0;
            const interval = setInterval(() => {
                phraseIndex++;
                if(phraseIndex < loadingPhrases.length) {
                    loadingText.style.opacity = '0';
                    loadingText.style.transform = 'translateY(10px)';
                    loadingSub.style.opacity = '0';
                    
                    setTimeout(() => {
                        loadingText.innerText = loadingPhrases[phraseIndex].main;
                        loadingSub.innerText = loadingPhrases[phraseIndex].sub;
                        loadingText.style.opacity = '1';
                        loadingText.style.transform = 'translateY(0)';
                        loadingSub.style.opacity = '1';
                    }, 1000); 
                } else {
                    clearInterval(interval);
                    showCinematicResults();
                }
            }, 2800); 

            return;
          }

          const nextStepId = clicked.dataset.next;
          if (nextStepId) {
            let progress = '33%';
            if (nextStepId === 'step-2') progress = '66%';
            if (nextStepId === 'step-3') progress = '100%';
            transitionToNextStep(currentStepId, nextStepId, progress);
          }
        });
      });

      function scoreProducts(productsList, keywords) {
          productsList.forEach(p => {
              p.score = 0;
              const searchString = `${p.title} ${p.description} ${p.tags.join(' ')}`.toLowerCase();
              keywords.forEach(kw => {
                  const regex = new RegExp(`\\b${kw}\\b`, 'i');
                  if (regex.test(searchString)) p.score += 1;
                  if (regex.test(p.title)) p.score += 2; 
              });
              p.score += Math.random() * 0.5;
          });
          return productsList.sort((a,b) => b.score - a.score);
      }

      function showCinematicResults() {
          const validProducts = allProducts.filter(p => p.price >= 35);
          
          let scoredProducts = scoreProducts([...validProducts], userPreferences.keywords);

          let inBudget = scoredProducts.filter(p => p.price >= userPreferences.min && p.price <= userPreferences.max);
          if (inBudget.length === 0) inBudget = scoredProducts; // Fallback

          // --- 1. THE PERFECT MATCH (Center) ---
          const match1 = inBudget[0];

          // --- 2. BEAUTIFUL ALTERNATIVE (Left Side) ---
          let match2 = inBudget.find(p => p.handle !== match1.handle && p.price !== match1.price);
          if (!match2) match2 = scoredProducts.find(p => p.handle !== match1.handle);

          // --- 3. SENSIBLE UPGRADE (Right Side) ---
          const highestCurrentPrice = Math.max(match1.price, match2 ? match2.price : 0);
          let upgradeMatches = scoredProducts.filter(p => 
              p.handle !== match1.handle && 
              (!match2 || p.handle !== match2.handle) &&
              p.price > highestCurrentPrice &&
              p.price <= highestCurrentPrice + 50
          );

          let match3 = upgradeMatches[0];
          if (!match3) {
              match3 = scoredProducts.find(p => p.handle !== match1.handle && (!match2 || p.handle !== match2.handle));
          }

          // Build Global Results Array for Lightbox
          window.currentLightboxData = [];
          if(match2) window.currentLightboxData.push({product: match2, label: "Beautiful Alternative", type: "side"});
          if(match1) window.currentLightboxData.push({product: match1, label: "The Perfect Match", type: "center"});
          if(match3) window.currentLightboxData.push({product: match3, label: "Sensible Upgrade", type: "side"});

          const grid = document.getElementById('results-grid');
          grid.innerHTML = ''; 
          
          window.currentLightboxData.forEach((item, index) => {
              grid.innerHTML += createProportionalCard(item.product, item.label, item.type, index);
          });

          const loadingView = document.getElementById('ai-loading-view');
          const resultsView = document.getElementById('ai-results-view');

          loadingView.classList.remove('opacity-100', 'scale-100');
          loadingView.classList.add('opacity-0', 'scale-95');

          setTimeout(() => {
              loadingView.classList.add('hidden');
              resultsView.classList.remove('hidden');
              
              requestAnimationFrame(() => {
                  resultsView.classList.remove('opacity-0', 'scale-105');
                  resultsView.classList.add('opacity-100', 'scale-100');
              });
          }, 1000);
      }

      // --- LIGHTBOX LOGIC ---
      window.openLightbox = function(index) {
          window.currentLightboxIndex = index;
          updateLightboxUI();
          
          const overlay = document.getElementById('lightbox-overlay');
          overlay.classList.remove('hidden');
          // small delay to allow display block to process before fading in
          setTimeout(() => overlay.classList.remove('opacity-0'), 10);
      }

      window.closeLightbox = function() {
          const overlay = document.getElementById('lightbox-overlay');
          overlay.classList.add('opacity-0');
          setTimeout(() => overlay.classList.add('hidden'), 300);
      }

      window.lightboxNext = function(e) {
          e.stopPropagation();
          window.currentLightboxIndex = (window.currentLightboxIndex + 1) % window.currentLightboxData.length;
          updateLightboxUI();
      }

      window.lightboxPrev = function(e) {
          e.stopPropagation();
          window.currentLightboxIndex = (window.currentLightboxIndex - 1 + window.currentLightboxData.length) % window.currentLightboxData.length;
          updateLightboxUI();
      }

      function updateLightboxUI() {
          const item = window.currentLightboxData[window.currentLightboxIndex];
          const imgEl = document.getElementById('lightbox-img');
          
          // Slight fade effect when switching images
          imgEl.style.opacity = 0;
          setTimeout(() => {
              imgEl.src = item.product.image;
              document.getElementById('lightbox-title').innerText = item.product.title;
              document.getElementById('lightbox-price').innerText = `£${item.product.price.toFixed(2)}`;
              document.getElementById('lightbox-badge').innerText = item.label;
              imgEl.style.opacity = 1;
          }, 150);
      }

      function createProportionalCard(product, label, type, index) {
          const isCenter = type === "center";
          
          // Styling differences based on hierarchy
          const badgeClass = isCenter ? "text-sb-black bg-sb-gold border-sb-gold" : "text-sb-cream bg-white/10 border-white/20";
          const borderClass = isCenter ? "border-sb-gold shadow-[0_0_25px_rgba(212,175,55,0.15)]" : "border-white/10";
          const desktopScale = isCenter ? "md:scale-105 md:z-20 md:w-[35%]" : "md:scale-95 md:z-10 md:w-[30%]";
          const hoverState = "hover:scale-[1.02] md:hover:scale-[1.08] hover:z-[60] hover:shadow-[0_20px_50px_rgba(0,0,0,0.5)]";

          return `
            <div class="flex flex-row md:flex-col w-full bg-white/5 border ${borderClass} transition-all duration-500 ease-out rounded-sm group relative backdrop-blur-sm h-auto shrink-0 ${desktopScale} ${hoverState}">
                
                <!-- Image Container with Click-to-Open-Lightbox -->
                <div class="w-[40%] md:w-full md:h-[30vh] md:max-h-[350px] md:min-h-[250px] relative overflow-hidden bg-black shrink-0 cursor-pointer" onclick="window.openLightbox(${index})">
                    <div class="absolute top-2 left-2 md:top-4 md:left-4 ${badgeClass} text-[9px] uppercase tracking-luxury font-bold px-3 py-1 z-30 border backdrop-blur-md hidden md:block shadow-sm">
                        ${label}
                    </div>
                    
                    <!-- View Full Overlay -->
                    <div class="absolute inset-0 bg-sb-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center z-20 backdrop-blur-[2px]">
                        <i class="fas fa-search-plus text-white text-3xl md:text-5xl drop-shadow-md"></i>
                    </div>

                    <!-- Clean image without zoom on hover -->
                    <img 
                        src="${product.image}" 
                        alt="${product.title}" 
                        class="absolute inset-0 w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-all duration-700 ease-out z-10" 
                        onerror="this.onerror=null; this.src='/images/collection-signature.jpg';"
                    />
                </div>
                
                <!-- Text Container: H-Auto ensures no text gets cut off -->
                <div class="w-[60%] md:w-full p-4 md:p-6 text-left md:text-center relative z-20 flex flex-col justify-center flex-grow bg-sb-black/80 md:bg-transparent backdrop-blur-sm md:backdrop-blur-none min-h-[9rem]">
                    <div class="md:hidden ${badgeClass} text-[8px] uppercase tracking-luxury font-bold px-2 py-1 mb-3 inline-block w-max border">
                        ${label}
                    </div>
                    <h4 class="font-serif text-[1.15rem] md:text-2xl text-white mb-2 leading-snug">${product.title}</h4>
                    <p class="text-sb-gold text-base md:text-lg font-light mb-4 md:mb-6">£${product.price.toFixed(2)}</p>
                    <a href="/products/${product.handle}" class="border border-white/20 text-white py-3 px-4 md:px-6 text-[10px] font-bold uppercase tracking-luxury group-hover:bg-sb-gold group-hover:text-sb-black group-hover:border-sb-gold transition-all duration-300 w-max md:w-full text-center mt-auto">
                        View Bouquet
                    </a>
                </div>
            </div>
          `;
      }

    });
  </script>
</Layout>
