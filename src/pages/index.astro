---
import Layout from '../layouts/Layout.astro';
import Testimonials from '../components/Testimonials.astro';
import { shopifyFetch } from '../utils/shopify.js';
import { Image } from 'astro:assets';
import heroImg from '../../public/images/hero.jpg';
import signatureImg from '../../public/images/collection-signature.jpg';

const targetTags = ['seasonal', 'luxury', 'gothic', 'fairytale'];
const queryBody = targetTags.map(tag => `
  ${tag}: products(first: 10, query: "tag:${tag} AND available_for_sale:true") {
    edges {
      node {
        images(first: 1) { edges { node { url } } }
      }
    }
  }
`).join('\n');
const query = `{ ${queryBody} }`;
const response = await shopifyFetch({ query });
const collectionsData = response?.data || {};
const collectionCards = targetTags.map(tag => {
  const products = collectionsData[tag]?.edges || [];
  const validProducts = products.filter(p => p.node?.images?.edges?.length > 0);
  let imgSrc = 'https://via.placeholder.com/600x800?text=Coming+Soon';
  
  if (validProducts.length > 0) {
    imgSrc = validProducts[0].node.images.edges[0].node.url;
  }
  
  return {
    tag: tag,
    title: tag.charAt(0).toUpperCase() + tag.slice(1),
    imgSrc: imgSrc,
    link: `/collections/${tag}`
  };
});
---

<Layout 
  title="Bespoke Luxury Florist Essex & London" 
  description="SB Floristry: A boutique mother & daughter studio crafting high-end floral arrangements for weddings, events, and luxury gifting. Local delivery across Essex."
>
  <!-- 1. HERO SECTION WITH SEGMENTED INTENT CTA -->
  <section class="relative h-[90vh] overflow-hidden">
      <div class="absolute inset-0">
          <Image 
            src={heroImg} 
            alt="SB Floristry Luxury Hand-Tied Bouquet" 
            class="w-full h-full object-cover hero-zoom opacity-90" 
            loading="eager"
            quality="high"
            style="object-position: center 60%;"
          />
          <div class="absolute inset-0 bg-black/50"></div>
          <div class="absolute bottom-0 left-0 w-full h-1/3 bg-gradient-to-t from-sb-black to-transparent"></div>
      </div>
      <div class="relative z-10 container mx-auto px-6 h-full flex flex-col justify-center items-center text-center text-sb-cream pt-20">
          <h2 class="text-xs md:text-sm tracking-[0.3em] uppercase mb-8 font-medium text-sb-gold animate-fade-in">Hand-Tied in Essex • Delivered to London</h2>
          <h1 class="font-serif text-6xl md:text-8xl lg:text-9xl mb-10 leading-none animate-fade-in-up font-normal">
              Artistry in <br><span class="italic font-light text-gold-metallic">Every Bloom</span>
          </h1>
          
          <div class="flex flex-col sm:flex-row gap-5 mt-4 animate-fade-in">
              <a href="/collections/seasonal" class="btn-luxury bg-sb-cream text-sb-black px-10 py-3.5 uppercase tracking-luxury text-xs font-bold hover:bg-white transition-colors">
                  Shop Luxury Gifting
              </a>
              <a href="/weddings" class="btn-luxury border border-sb-cream/40 text-sb-cream px-10 py-3.5 uppercase tracking-luxury text-xs font-bold hover:border-sb-gold transition-colors backdrop-blur-sm bg-black/20">
                  Inquire for Weddings
              </a>
          </div>
      </div>
  </section>
  
  <section class="py-24 bg-sb-black text-sb-cream relative border-t border-white/5">
      <div class="container mx-auto px-6 text-center max-w-2xl">
          <span class="text-gold-metallic text-2xl mb-6 block reveal"><i class="fas fa-leaf"></i></span>
          <h2 class="font-serif text-4xl md:text-5xl text-sb-cream mb-8 reveal font-light text-shadow-sm">A Family Affair</h2>
          <p class="text-gray-400 leading-relaxed text-xl font-light mb-12 reveal">
              Welcome to SB Floristry. We are a mother and daughter team bringing bespoke, luxury floral design to weddings, events, and homes across Essex and London. Every arrangement is hand-selected and styled with the care only family can provide.
          </p>
          <div class="flex flex-col md:flex-row justify-center gap-12 text-xs font-bold tracking-luxury text-sb-cream uppercase reveal">
              <div class="flex items-center justify-center"><i class="fas fa-truck mr-3 text-sb-gold"></i> Free Local Delivery</div>
              <div class="flex items-center justify-center"><i class="fas fa-heart mr-3 text-sb-gold"></i> Family Owned</div>
          </div>
      </div>
  </section>

  <!-- COLLECTIONS GRID -->
  <section class="py-24 bg-sb-cream">
    <div class="container mx-auto px-6">
        <div class="text-center mb-16 reveal">
            <h3 class="font-serif text-5xl text-sb-black mb-4 font-light">Explore Our Collections</h3>
            <div class="w-16 h-px bg-sb-gold mx-auto mt-6"></div>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" id="home-collections-grid">
            {collectionCards.map((card) => (
                <a href={card.link} class="group relative block h-[500px] overflow-hidden cursor-pointer reveal">
                    <img 
                      src={card.imgSrc} 
                      alt={card.title} 
                      class="w-full h-full object-cover transition-transform duration-[1.5s] group-hover:scale-105" 
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-colors duration-500"></div>
                    <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-4">
                        <h4 class="font-serif text-4xl text-sb-cream mb-2 translate-y-4 group-hover:translate-y-0 transition-transform duration-500 font-light">{card.title}</h4>
                        <span class="text-sb-cream text-xs tracking-luxury uppercase border-b border-transparent group-hover:border-sb-cream pb-1 opacity-0 group-hover:opacity-100 transition-all duration-500 delay-100">View Collection</span>
                    </div>
                </a>
            ))}
        </div>
    </div>
  </section>

  <!-- 2. SOCIAL PROOF / INLINE QUOTE -->
  <section class="py-20 bg-sb-black border-t border-b border-white/5 relative overflow-hidden">
      <!-- Subtle background elements -->
      <div class="absolute -top-24 -right-24 w-64 h-64 bg-sb-gold/5 rounded-full blur-3xl"></div>
      <div class="container mx-auto px-6 text-center max-w-4xl relative z-10 reveal">
          <i class="fas fa-quote-left text-sb-gold text-3xl mb-8 opacity-60"></i>
          <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-sb-cream font-light leading-snug mb-8">
              "An absolute fairytale. The attention to detail, styling, and sheer quality of the blooms were unparalleled. Truly an art form."
          </h2>
          <p class="text-xs uppercase tracking-[0.3em] text-sb-gold font-bold">— Premium Wedding Client</p>
      </div>
  </section>

  <!-- 6. EDITORIAL SUBSCRIPTIONS HIGHLIGHT -->
  <section class="py-0 bg-sb-black flex flex-col md:flex-row">
      <div class="w-full md:w-1/2 min-h-[400px] md:min-h-[600px] relative reveal">
          <!-- Using standard img tag pointing to public folder to guarantee it works -->
          <img 
            src="/images/collection-seasonal.jpg" 
            alt="Luxury Flower Subscriptions" 
            class="absolute inset-0 w-full h-full object-cover" 
            loading="lazy" 
          />
          <div class="absolute inset-0 bg-sb-black/30 md:hidden"></div>
      </div>
      <div class="w-full md:w-1/2 flex items-center justify-center p-12 md:p-24 bg-sb-cream text-sb-black reveal">
          <div class="max-w-md text-center md:text-left">
              <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-4 block">Recurring Luxury</span>
              <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl mb-6 font-light leading-tight">The Editorial <br />Subscription</h2>
              <p class="text-gray-600 font-light mb-10 text-base md:text-lg leading-relaxed">
                  Bring constant artistry into your home or office space. Receive hand-tied, artfully curated seasonal bouquets delivered directly to your door on a schedule that suits you.
              </p>
              <a href="/subscriptions" class="inline-block border border-sb-black text-sb-black py-4 px-10 text-[10px] md:text-xs font-bold uppercase tracking-luxury hover:bg-sb-black hover:text-sb-cream transition-all duration-500">
                  Explore Subscriptions
              </a>
          </div>
      </div>
  </section>

  <!-- 7. INTERACTIVE CONVERSION CAPTURE (Occasion Finder) -->
  <section class="py-24 md:py-32 bg-sb-black text-white relative overflow-hidden border-t border-white/5">
    <div class="absolute inset-0 z-0">
      <Image 
        src={signatureImg} 
        alt="Bespoke luxury flower arrangement" 
        class="w-full h-full object-cover opacity-30 md:opacity-40" 
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-sb-black via-sb-black/95 to-transparent"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10 flex flex-col md:flex-row items-center">
      <div class="w-full md:w-1/2 md:pr-12 text-center md:text-left reveal">
        <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-4 block"><i class="fas fa-magic mr-2"></i> Interactive Studio Guide</span>
        <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-white mb-10 font-light leading-tight">Who are we <br class="hidden md:block" />designing for?</h2>
        
        <!-- Interactive Prompt Links -->
        <div class="flex flex-col gap-4 max-w-md mx-auto md:mx-0">
            <a href="/occasion-finder?for=special" class="group flex items-center justify-between border border-white/20 bg-black/40 backdrop-blur-sm hover:bg-sb-gold hover:border-sb-gold py-5 px-6 transition-all duration-300">
                <span class="text-xs font-bold uppercase tracking-luxury text-sb-cream group-hover:text-sb-black">Someone Special</span>
                <i class="fas fa-arrow-right text-sb-gold group-hover:text-sb-black transition-colors"></i>
            </a>
            <a href="/occasion-finder?for=home" class="group flex items-center justify-between border border-white/20 bg-black/40 backdrop-blur-sm hover:bg-sb-gold hover:border-sb-gold py-5 px-6 transition-all duration-300">
                <span class="text-xs font-bold uppercase tracking-luxury text-sb-cream group-hover:text-sb-black">My Own Home</span>
                <i class="fas fa-arrow-right text-sb-gold group-hover:text-sb-black transition-colors"></i>
            </a>
            <a href="/occasion-finder?for=corporate" class="group flex items-center justify-between border border-white/20 bg-black/40 backdrop-blur-sm hover:bg-sb-gold hover:border-sb-gold py-5 px-6 transition-all duration-300">
                <span class="text-xs font-bold uppercase tracking-luxury text-sb-cream group-hover:text-sb-black">A Corporate Event</span>
                <i class="fas fa-arrow-right text-sb-gold group-hover:text-sb-black transition-colors"></i>
            </a>
            <a href="/occasion-finder?for=custom" class="group flex items-center justify-between border border-white/20 bg-black/40 backdrop-blur-sm hover:bg-sb-gold hover:border-sb-gold py-5 px-6 transition-all duration-300">
                <span class="text-xs font-bold uppercase tracking-luxury text-sb-cream group-hover:text-sb-black">A Bespoke Commission</span>
                <i class="fas fa-arrow-right text-sb-gold group-hover:text-sb-black transition-colors"></i>
            </a>
        </div>
      </div>
    </div>
  </section>

  <Testimonials />

  <section class="py-24 bg-sb-black text-sb-cream border-t border-white/5" id="contact-section">
      <div class="container mx-auto px-6 max-w-4xl">
          <div class="text-center mb-12 reveal">
              <h3 class="font-serif text-5xl md:text-6xl text-sb-cream mb-4 font-light">Start Your Floral Journey</h3>
              <p class="font-light text-gray-400 text-lg">Tell us about your event or custom request.</p>
          </div>
          <form id="home-contact-form" class="space-y-8 reveal">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-name">Name</label>
                      <input type="text" id="contact-name" name="name" required class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream placeholder-gray-600 text-base">
                  </div>
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-email">Email</label>
                      <input type="email" id="contact-email" name="email" required class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream placeholder-gray-600 text-base">
                  </div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-date">Event Date (Optional)</label>
                      <input type="date" id="contact-date" name="date" class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream text-gray-400 text-base">
                  </div>
                  <div class="space-y-1">
                      <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-interest">Interest</label>
                      <select id="contact-interest" name="interest" class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream text-base">
                          <option value="Weddings" class="bg-sb-black text-white">Weddings</option>
                          <option value="Events" class="bg-sb-black text-white">Events</option>
                          <option value="Hotels" class="bg-sb-black text-white">Hotels & Spas</option>
                          <option value="Bespoke Order" class="bg-sb-black text-white">Bespoke Order</option>
                      </select>
                  </div>
              </div>
              <div class="space-y-1">
                  <label class="text-xs font-bold tracking-luxury uppercase text-sb-gold" for="contact-message">Message</label>
                  <textarea id="contact-message" name="message" rows="4" required class="w-full bg-transparent border-b border-gray-700 focus:border-sb-gold outline-none py-2 transition-colors text-sb-cream placeholder-gray-600 text-base"></textarea>
              </div>
              <div class="text-center pt-8">
                  <button type="submit" class="btn-luxury border border-sb-cream text-sb-cream px-16 py-4 uppercase tracking-luxury text-xs font-bold inline-block">
                      Send Inquiry
                  </button>
              </div>
          </form>
      </div>
  </section>
</Layout>
