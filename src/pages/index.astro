---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import Testimonials from '../components/Testimonials.astro';
import { shopifyFetch } from '../utils/shopify.js';

// Define the GraphQL query to fetch products
const query = `
  {
    products(first: 8) {
      edges {
        node {
          id
          title
          handle
          images(first: 2) {
            edges {
              node {
                url
              }
            }
          }
          priceRange {
            minVariantPrice {
              amount
              currencyCode
            }
          }
          variants(first: 1) {
            edges {
              node {
                id
                price {
                  amount
                  currencyCode
                }
              }
            }
          }
        }
      }
    }
  }
`;

// Fetch data from Shopify
const response = await shopifyFetch({ query });
const products = response?.data?.products?.edges || [];
---

<Layout title="SB Floristry | Luxury Essex Florist">
  
  <!-- Hero Section -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/images/hero.jpg" alt="Luxury floral arrangement" class="w-full h-full object-cover opacity-60" />
      <div class="absolute inset-0 bg-sb-black/50"></div>
    </div>
    
    <div class="relative z-10 text-center px-6 reveal">
      <span class="text-sb-gold text-xs md:text-sm tracking-luxury uppercase font-bold mb-4 block">Bespoke Floral Design</span>
      <h2 class="font-serif text-5xl md:text-7xl lg:text-8xl text-sb-cream mb-6 font-light">Elegance in<br/>Every Stem</h2>
      <p class="text-gray-300 font-light max-w-lg mx-auto mb-10 text-sm md:text-base">Hand-tied luxury bouquets and styling for weddings and events across Essex.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/collections/seasonal" class="bg-sb-gold text-sb-black px-8 py-4 text-xs font-bold uppercase tracking-luxury hover:bg-white transition-colors duration-300">Shop Collection</a>
        <a href="/weddings" class="border border-sb-gold text-sb-gold px-8 py-4 text-xs font-bold uppercase tracking-luxury hover:bg-sb-gold hover:text-sb-black transition-colors duration-300">Weddings & Events</a>
      </div>
    </div>
  </section>

  <!-- Welcome / About Teaser -->
  <section class="py-24 bg-sb-cream text-sb-black text-center px-6">
    <div class="max-w-3xl mx-auto reveal">
      <h3 class="font-serif text-3xl md:text-5xl mb-8 font-light">A Family Affair</h3>
      <p class="text-gray-600 font-light leading-relaxed mb-8 text-sm md:text-base">
        At SB Floristry, we believe flowers are more than just a gift; they are a gesture, a memory, and a piece of art. As a family-run business based in the heart of Essex, we pour our passion into every arrangement, ensuring that from the moment they leave our hands to the moment they arrive in yours, the experience is nothing short of luxurious.
      </p>
      <a href="/our-story" class="inline-block border-b border-sb-black pb-1 text-xs uppercase font-bold tracking-luxury hover:text-sb-gold hover:border-sb-gold transition-colors">Discover Our Story</a>
    </div>
  </section>

  <!-- Featured Products / Seasonal Edit -->
  <section class="py-24 bg-white text-sb-black">
    <div class="container mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 reveal">
        <div>
          <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-2 block">Latest Arrivals</span>
          <h3 class="font-serif text-4xl md:text-5xl font-light">The Seasonal Edit</h3>
        </div>
        <a href="/collections/seasonal" class="hidden md:inline-block border-b border-sb-black pb-1 text-[10px] uppercase font-bold tracking-luxury hover:text-sb-gold hover:border-sb-gold transition-colors">View All</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-16">
        {products.slice(0, 4).map((product, index) => (
          <div class="reveal" style={`transition-delay: ${index * 100}ms;`}>
            <ProductCard product={product.node} isDark={false} />
          </div>
        ))}
      </div>
      
      <div class="mt-12 text-center md:hidden reveal">
         <a href="/collections/seasonal" class="inline-block border-b border-sb-black pb-1 text-[10px] uppercase font-bold tracking-luxury hover:text-sb-gold hover:border-sb-gold transition-colors">View All Collection</a>
      </div>
    </div>
  </section>

  <!-- Signature Collections (Visual Links) -->
  <section class="py-4 bg-white">
     <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
        <!-- Collection 1 -->
        <a href="/collections/signature" class="group relative h-[60vh] overflow-hidden reveal">
           <img src="/images/collection-signature.jpg" alt="Signature Collection" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
           <div class="absolute inset-0 bg-black/30 group-hover:bg-black/40 transition-colors duration-500"></div>
           <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-6">
              <h4 class="font-serif text-3xl md:text-4xl text-white mb-4 font-light">Signature</h4>
              <span class="text-white border-b border-white pb-1 text-[10px] uppercase font-bold tracking-luxury group-hover:text-sb-gold group-hover:border-sb-gold transition-colors">Shop Now</span>
           </div>
        </a>

        <!-- Collection 2 -->
        <a href="/weddings" class="group relative h-[60vh] overflow-hidden reveal">
           <img src="/images/collection-weddings.jpg" alt="Weddings Collection" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
           <div class="absolute inset-0 bg-black/30 group-hover:bg-black/40 transition-colors duration-500"></div>
           <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-6">
              <h4 class="font-serif text-3xl md:text-4xl text-white mb-4 font-light">Weddings</h4>
              <span class="text-white border-b border-white pb-1 text-[10px] uppercase font-bold tracking-luxury group-hover:text-sb-gold group-hover:border-sb-gold transition-colors">Discover</span>
           </div>
        </a>

        <!-- Collection 3 -->
        <a href="/funerals" class="group relative h-[60vh] overflow-hidden reveal md:col-span-2 lg:col-span-1">
           <img src="/images/collection-sympathy.jpg" alt="Sympathy Collection" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
           <div class="absolute inset-0 bg-black/30 group-hover:bg-black/40 transition-colors duration-500"></div>
           <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-6">
              <h4 class="font-serif text-3xl md:text-4xl text-white mb-4 font-light">Sympathy</h4>
              <span class="text-white border-b border-white pb-1 text-[10px] uppercase font-bold tracking-luxury group-hover:text-sb-gold group-hover:border-sb-gold transition-colors">Shop Now</span>
           </div>
        </a>
     </div>
  </section>

  <!-- Gift Concierge Teaser Section -->
  <section class="py-20 md:py-32 bg-sb-black text-white relative overflow-hidden">
    <!-- Background Image with Fade Overlay -->
    <div class="absolute inset-0 z-0">
      <img src="/images/collection-signature.jpg" alt="Signature luxury flowers" class="w-full h-full object-cover opacity-40 md:opacity-50" />
      <!-- Gradient overlay to ensure text is perfectly readable -->
      <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-sb-black via-sb-black/90 to-transparent"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10 flex flex-col md:flex-row items-center">
      <div class="w-full md:w-1/2 md:pr-12 text-center md:text-left reveal">
        <span class="text-sb-gold text-[10px] tracking-luxury uppercase font-bold mb-4 block"><i class="fas fa-magic mr-2"></i> Need some inspiration?</span>
        <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-white mb-6 font-light leading-tight">Meet Your <br class="hidden md:block" />Virtual Concierge</h2>
        
        <p class="text-gray-300 font-light mb-8 md:mb-10 text-base md:text-lg leading-relaxed max-w-md mx-auto md:mx-0">
          Finding the perfect arrangement shouldn't be guesswork. Answer three simple questions about your recipient, and let our intelligent gift finder curate a bespoke selection.
        </p>
        
        <a href="/occasion-finder" class="inline-block border border-sb-gold text-sb-gold py-4 px-8 text-[10px] md:text-xs font-bold uppercase tracking-luxury hover:bg-sb-gold hover:text-sb-black transition-all duration-500 shadow-xl hover:shadow-[0_0_20px_rgba(212,175,55,0.3)]">
          Launch Gift Finder
        </a>
      </div>
    </div>
  </section>

  <Testimonials />
</Layout>
