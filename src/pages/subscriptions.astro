---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Luxury Floral Subscriptions | SB Floristry">
  <Header />

  <main class="pt-24 pb-20 bg-[#F9F8F6]">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h1 class="font-serif text-4xl md:text-5xl text-sb-black mb-6">Floral Subscriptions</h1>
      <p class="text-gray-600 max-w-2xl mx-auto mb-16 tracking-wide">Enjoy fresh, luxury seasonal blooms delivered directly to your door. Choose your tier, set your frequency, and let us handle the rest.</p>

      <!-- Pricing Cards -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 max-w-6xl mx-auto">
        <!-- Developer Test Tier (For Sandbox Banking Tests) -->
        <div class="bg-white p-8 border border-gray-200 flex flex-col justify-between">
          <div>
            <h3 class="font-serif text-2xl text-sb-black mb-2">Developer Test</h3>
            <p class="text-sb-gold font-bold text-xl mb-4">£1.00 <span class="text-xs text-gray-400 font-normal">/ delivery</span></p>
            <p class="text-sm text-gray-500 mb-6">QA Testing Tier</p>
          </div>
          <button data-plan="test" class="subscribe-btn w-full border border-sb-black text-sb-black py-3 uppercase tracking-widest text-xs hover:bg-sb-black hover:text-white transition-colors">Test Flow</button>
        </div>

        <div class="bg-white p-8 border border-gray-200 flex flex-col justify-between">
          <div>
            <h3 class="font-serif text-2xl text-sb-black mb-2">The Classic</h3>
            <p class="text-sb-gold font-bold text-xl mb-4">£40.00 <span class="text-xs text-gray-400 font-normal">/ delivery</span></p>
            <p class="text-sm text-gray-500 mb-6">Beautiful, seasonal stems arranged elegantly for your home.</p>
          </div>
          <button data-plan="classic" class="subscribe-btn w-full border border-sb-black text-sb-black py-3 uppercase tracking-widest text-xs hover:bg-sb-black hover:text-white transition-colors">Select Classic</button>
        </div>

        <div class="bg-sb-black text-white p-8 border border-sb-black flex flex-col justify-between transform md:-translate-y-4 shadow-xl">
          <div>
            <p class="text-[10px] text-sb-gold uppercase tracking-[0.2em] mb-4">Most Popular</p>
            <h3 class="font-serif text-2xl mb-2">The Signature</h3>
            <p class="text-sb-gold font-bold text-xl mb-4">£65.00 <span class="text-xs text-gray-400 font-normal">/ delivery</span></p>
            <p class="text-sm text-gray-400 mb-6">A fuller, premium arrangement featuring our signature focal blooms.</p>
          </div>
          <button data-plan="signature" class="subscribe-btn w-full bg-sb-gold text-sb-black py-3 uppercase tracking-widest text-xs hover:bg-white transition-colors font-bold">Select Signature</button>
        </div>

        <div class="bg-white p-8 border border-gray-200 flex flex-col justify-between">
          <div>
            <h3 class="font-serif text-2xl text-sb-black mb-2">The Luxe</h3>
            <p class="text-sb-gold font-bold text-xl mb-4">£100.00 <span class="text-xs text-gray-400 font-normal">/ delivery</span></p>
            <p class="text-sm text-gray-500 mb-6">A breathtaking, show-stopping display of absolute luxury.</p>
          </div>
          <button data-plan="luxe" class="subscribe-btn w-full border border-sb-black text-sb-black py-3 uppercase tracking-widest text-xs hover:bg-sb-black hover:text-white transition-colors">Select Luxe</button>
        </div>
      </div>
    </div>
  </main>

  <!-- Subscription Checkout Modal -->
  <div id="subModal" class="fixed inset-0 bg-black/70 z-[100] hidden opacity-0 transition-opacity duration-300 backdrop-blur-sm flex items-center justify-center p-4 overflow-y-auto">
    <div id="subModalContent" class="bg-white w-full max-w-lg relative transform scale-95 transition-transform duration-300 my-auto">
      
      <button id="closeSubModal" type="button" class="absolute top-4 right-4 text-gray-400 hover:text-sb-black transition-colors z-10">
        <i class="fas fa-times text-xl"></i>
      </button>

      <div class="p-8">
        <h2 class="font-serif text-3xl text-sb-black mb-2">Complete Setup</h2>
        <p id="modalPlanName" class="text-sb-gold font-bold tracking-wide mb-6">The Subscription</p>

        <form id="subscriptionForm" class="space-y-4">
          <input type="hidden" id="planTier" name="planTier" value="">

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-gray-500 mb-1">First Name</label>
              <input type="text" name="firstName" required class="w-full border border-gray-200 p-3 text-sm focus:border-sb-gold outline-none transition-colors" placeholder="Jane">
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-gray-500 mb-1">Last Name</label>
              <input type="text" name="lastName" required class="w-full border border-gray-200 p-3 text-sm focus:border-sb-gold outline-none transition-colors" placeholder="Doe">
            </div>
          </div>

          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-gray-500 mb-1">Email Address</label>
            <input type="email" name="email" required class="w-full border border-gray-200 p-3 text-sm focus:border-sb-gold outline-none transition-colors" placeholder="jane@example.com">
          </div>

          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-gray-500 mb-1">Address Line 1</label>
            <input type="text" name="address1" required class="w-full border border-gray-200 p-3 text-sm focus:border-sb-gold outline-none transition-colors" placeholder="123 Floral Street">
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-gray-500 mb-1">Town / City</label>
              <input type="text" name="city" required class="w-full border border-gray-200 p-3 text-sm focus:border-sb-gold outline-none transition-colors" placeholder="London">
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-gray-500 mb-1">Postcode</label>
              <input type="text" name="postcode" required class="w-full border border-gray-200 p-3 text-sm focus:border-sb-gold outline-none transition-colors" placeholder="E1 8QA">
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-gray-500 mb-1">Delivery Frequency</label>
              <select name="frequency" required class="w-full border border-gray-200 p-3 text-sm focus:border-sb-gold outline-none bg-white transition-colors">
                <option value="Weekly">Weekly</option>
                <option value="Fortnightly">Fortnightly</option>
                <option value="Monthly">Monthly</option>
              </select>
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-gray-500 mb-1">Reason</label>
              <select name="reason" required class="w-full border border-gray-200 p-3 text-sm focus:border-sb-gold outline-none bg-white transition-colors">
                <option value="Treating Myself">Treating Myself</option>
                <option value="Gift for Someone">Gift for Someone</option>
                <option value="Corporate / Office">Corporate / Office</option>
              </select>
            </div>
          </div>

          <div class="pt-4">
            <button type="submit" id="submitFormBtn" class="w-full bg-sb-gold text-sb-black hover:bg-sb-black hover:text-white transition-colors duration-300 py-4 text-[11px] uppercase tracking-[0.25em] font-bold shadow-lg shadow-sb-gold/20 flex items-center justify-center gap-2">
              Setup Direct Debit <i class="fas fa-lock text-[10px]"></i>
            </button>
            <p class="text-[10px] text-gray-400 text-center mt-3">You will be securely redirected to GoCardless to authorize your mandate.</p>
          </div>
        </form>

      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const modal = document.getElementById("subModal");
    const modalContent = document.getElementById("subModalContent");
    const closeBtn = document.getElementById("closeSubModal");
    const planInput = document.getElementById("planTier");
    const planNameDisplay = document.getElementById("modalPlanName");
    const form = document.getElementById("subscriptionForm");
    const submitBtn = document.getElementById("submitFormBtn");

    const openModal = (plan) => {
      if (!modal || !planInput || !planNameDisplay) return;
      planInput.value = plan;
      planNameDisplay.innerText = `The ${plan.charAt(0).toUpperCase() + plan.slice(1)} Subscription`;
      
      modal.classList.remove("hidden");
      document.body.style.overflow = 'hidden';
      
      setTimeout(() => {
        modal.classList.remove("opacity-0");
        if (modalContent) modalContent.classList.remove("scale-95");
      }, 10);
    };

    const closeModal = () => {
      if (!modal) return;
      modal.classList.add("opacity-0");
      if (modalContent) modalContent.classList.add("scale-95");
      document.body.style.overflow = '';
      
      setTimeout(() => modal.classList.add("hidden"), 300);
    };

    document.querySelectorAll(".subscribe-btn").forEach(btn => {
      btn.addEventListener("click", (e) => {
        const plan = e.currentTarget.getAttribute("data-plan");
        if (plan) openModal(plan);
      });
    });

    closeBtn?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!submitBtn) return;

      const originalText = submitBtn.innerHTML;
      submitBtn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Securely Initializing...';
      submitBtn.disabled = true;

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      try {
        const response = await fetch("/api/gocardless/create-checkout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.checkoutUrl) {
          window.location.href = result.checkoutUrl;
        } else {
          throw new Error(result.error || "No checkout URL returned");
        }
      } catch (err) {
        console.error("Payment initialization failed:", err);
        submitBtn.innerHTML = "Error - Please Try Again";
        submitBtn.disabled = false;
        setTimeout(() => {
          submitBtn.innerHTML = originalText;
        }, 3000);
      }
    });
  });
</script>
