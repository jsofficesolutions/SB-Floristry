---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Floral Subscriptions | SB Floristry" description="Subscribe to regular luxury flower deliveries in Essex. Set up easily via Direct Debit.">
  
  <!-- Hero Section -->
  <section class="relative min-h-[80vh] flex items-center justify-center bg-sb-black text-sb-cream overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/images/collection-signature.jpg" alt="Luxury Subscription Flowers" class="w-full h-full object-cover opacity-60 hero-zoom" />
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-sb-black"></div>
    </div>
    <div class="container mx-auto px-6 relative z-10 text-center reveal mt-20">
      <span class="text-sb-gold text-xs tracking-luxury uppercase font-bold mb-6 block">The SB Subscription</span>
      <h1 class="font-serif text-5xl md:text-8xl mb-8 font-light tracking-wide">Endless <br/><span class="italic text-sb-gold">Elegance</span></h1>
      <p class="text-lg md:text-xl font-light text-gray-300 max-w-xl mx-auto leading-relaxed">
        Curated seasonal blooms delivered seamlessly to your door. Managed securely via direct debit, paused or cancelled at any time.
      </p>
    </div>
  </section>

  <!-- Editorial Tier Section -->
  <section class="py-32 bg-sb-cream text-sb-black">
    <div class="container mx-auto px-6 max-w-6xl">
      
      <!-- The Classic -->
      <div class="flex flex-col md:flex-row items-center gap-16 mb-32 reveal">
        <div class="w-full md:w-1/2">
          <div class="aspect-[4/5] overflow-hidden relative group">
            <img src="/images/product-wild-meadow.jpg" alt="The Classic Subscription" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
          </div>
        </div>
        <div class="w-full md:w-1/2 md:pl-12">
          <span class="text-sb-gold text-xs tracking-luxury uppercase font-bold mb-4 block">Tier 01</span>
          <h2 class="font-serif text-4xl md:text-5xl mb-4 text-sb-black">The Classic</h2>
          <p class="text-xl text-gray-500 mb-6 font-light">£40 <span class="text-sm uppercase tracking-wider">/ delivery</span></p>
          <p class="text-gray-600 font-light leading-relaxed mb-8">
            A petite, perfectly formed arrangement ideal for bedside tables, small desks, or cozy corners. Featuring 15-20 stems of the season's finest focal flowers.
          </p>
          <ul class="text-sm text-gray-500 space-y-4 mb-10 font-light border-l border-sb-gold/30 pl-6">
            <li>Includes free local delivery</li>
            <li>Bespoke seasonal selection</li>
            <li>Pause or cancel anytime</li>
          </ul>
          <button data-plan="classic" class="subscribe-btn inline-block bg-transparent border border-sb-black text-sb-black px-10 py-4 text-xs font-bold uppercase tracking-luxury hover:bg-sb-black hover:text-sb-gold transition-colors duration-300">
            Subscribe Now
          </button>
        </div>
      </div>

      <!-- The Signature -->
      <div class="flex flex-col md:flex-row-reverse items-center gap-16 mb-32 reveal">
        <div class="w-full md:w-1/2">
          <div class="aspect-[4/5] overflow-hidden relative group">
            <img src="/images/product-pure-elegance.jpg" alt="The Signature Subscription" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
            <div class="absolute top-6 right-6 bg-sb-gold text-sb-black text-[9px] uppercase font-bold tracking-luxury px-4 py-2">Most Popular</div>
          </div>
        </div>
        <div class="w-full md:w-1/2 md:pr-12">
          <span class="text-sb-gold text-xs tracking-luxury uppercase font-bold mb-4 block">Tier 02</span>
          <h2 class="font-serif text-4xl md:text-5xl mb-4 text-sb-black">The Signature</h2>
          <p class="text-xl text-gray-500 mb-6 font-light">£65 <span class="text-sm uppercase tracking-wider">/ delivery</span></p>
          <p class="text-gray-600 font-light leading-relaxed mb-8">
            Our standard size. A beautiful, medium-sized bouquet that creates a stunning centerpiece for any room. Approximately 25-35 stems of premium focal and filler flowers.
          </p>
          <ul class="text-sm text-gray-500 space-y-4 mb-10 font-light border-l border-sb-gold/30 pl-6">
            <li>Free glass vase with first order</li>
            <li>Premium stems & varied textures</li>
            <li>Flexible delivery schedule</li>
          </ul>
          <button data-plan="signature" class="subscribe-btn inline-block bg-sb-black border border-sb-black text-sb-gold px-10 py-4 text-xs font-bold uppercase tracking-luxury hover:bg-sb-gold hover:text-sb-black hover:border-sb-gold transition-colors duration-300 shadow-xl">
            Subscribe Now
          </button>
        </div>
      </div>

      <!-- The Luxe -->
      <div class="flex flex-col md:flex-row items-center gap-16 reveal">
        <div class="w-full md:w-1/2">
          <div class="aspect-[4/5] overflow-hidden relative group">
            <img src="/images/product-essex-rose.jpg" alt="The Luxe Subscription" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
          </div>
        </div>
        <div class="w-full md:w-1/2 md:pl-12">
          <span class="text-sb-gold text-xs tracking-luxury uppercase font-bold mb-4 block">Tier 03</span>
          <h2 class="font-serif text-4xl md:text-5xl mb-4 text-sb-black">The Luxe</h2>
          <p class="text-xl text-gray-500 mb-6 font-light">£100 <span class="text-sm uppercase tracking-wider">/ delivery</span></p>
          <p class="text-gray-600 font-light leading-relaxed mb-8">
            A show-stopping, abundant arrangement designed to impress. Features 45-60 of our most premium, rare, and luxurious stems including Orchids and Peonies.
          </p>
          <ul class="text-sm text-gray-500 space-y-4 mb-10 font-light border-l border-sb-gold/30 pl-6">
            <li>Priority delivery scheduling</li>
            <li>Exclusive, rare floral varieties</li>
            <li>Statement sizing and presentation</li>
          </ul>
          <button data-plan="luxe" class="subscribe-btn inline-block bg-transparent border border-sb-black text-sb-black px-10 py-4 text-xs font-bold uppercase tracking-luxury hover:bg-sb-black hover:text-sb-gold transition-colors duration-300">
            Subscribe Now
          </button>
        </div>
      </div>

    </div>
  </section>

  <!-- GoCardless Trust Banner -->
  <section class="py-12 bg-white border-y border-gray-100">
    <div class="container mx-auto px-6 text-center">
      <p class="text-[10px] uppercase tracking-luxury text-gray-400 mb-4 font-bold">Secure Payments Powered By</p>
      <div class="flex justify-center items-center gap-8 opacity-60 grayscale">
        <span class="font-sans font-bold text-xl tracking-tighter">GOCARDLESS</span>
        <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
        <span class="font-sans font-bold text-xl tracking-tighter">Direct Debit</span>
      </div>
    </div>
  </section>

</Layout>

<script>
  document.querySelectorAll('.subscribe-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget;
      const originalText = target.innerHTML;
      target.innerHTML = 'Processing...';
      target.disabled = true;
      
      const plan = target.getAttribute('data-plan');
      
      try {
        const response = await fetch('/api/gocardless/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ planTier: plan })
        });
        
        const data = await response.json();
        
        if (data.checkoutUrl) {
          window.location.href = data.checkoutUrl;
        } else {
          throw new Error(data.error || 'No checkout URL returned');
        }
      } catch (error) {
        console.error('Payment initialization failed:', error);
        target.innerHTML = 'Error - Try Again';
        target.disabled = false;
        setTimeout(() => {
          target.innerHTML = originalText;
        }, 3000);
      }
    });
  });
</script>
