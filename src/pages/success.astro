---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You | SB Floristry" description="Your luxury floral subscription has been confirmed.">
  <section class="min-h-screen flex items-center justify-center bg-sb-cream text-sb-black py-32">
    <div class="container mx-auto px-6 max-w-2xl text-center reveal">
      <div class="mb-8 flex justify-center">
        <div class="w-16 h-16 border border-sb-gold rounded-full flex items-center justify-center text-sb-gold">
          <i class="fas fa-check text-2xl"></i>
        </div>
      </div>
      
      <span class="text-sb-gold text-xs tracking-luxury uppercase font-bold mb-4 block">Thank You</span>
      <h1 class="font-serif text-4xl md:text-6xl mb-6 font-light">Subscription Confirmed</h1>
      <p class="text-gray-600 font-light leading-relaxed mb-10 max-w-md mx-auto">
        Your luxury direct debit mandate has been successfully initiated. We will curating your first design and deliver it beautifully on our next scheduled cycle.
      </p>

      <div class="border-t border-gray-200 pt-8 mb-10">
        <p class="text-xs text-gray-400 uppercase tracking-widest font-semibold mb-2">Need to update your dates?</p>
        <p class="text-sm text-gray-500 font-light">Email Bilja at <a href="mailto:info@sbfloristry.co.uk" class="text-sb-black underline hover:text-sb-gold transition-colors">info@sbfloristry.co.uk</a></p>
      </div>

      <a href="/" class="inline-block bg-sb-black text-sb-gold px-10 py-4 text-xs font-bold uppercase tracking-luxury hover:bg-sb-gold hover:text-sb-black transition-colors duration-300">
        Return Home
      </a>
    </div>
  </section>
</Layout>
